# See ENV.md for the full inventory.
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.

# --- Required ---
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_CALENDAR_ID=
GHL_WORKFLOW_LEAD_MAGNET_ID=
GHL_WORKFLOW_CONTACT_AUTORESPONDER_ID=
SITE_URL=https://dodiekendall.com
PUBLIC_PLAUSIBLE_DOMAIN=dodiekendall.com

# Meta (Facebook) Pixel ID — 15-16 digit numeric ID from Facebook Events Manager.
# When set, src/components/shared/MetaPixel.astro emits the pixel base code +
# PageView tracking on every page. Leave blank to render nothing.
PUBLIC_FB_PIXEL_ID=

# --- Fallback email (decide provider in ADR-003) ---
# Pick one:
RESEND_API_KEY=
# POSTMARK_SERVER_TOKEN=
FALLBACK_EMAIL_TO=dodiekendall@gmail.com
FALLBACK_EMAIL_FROM=no-reply@dodiekendall.com

# --- Optional / future ---
# SENTRY_DSN=
# LOGFLARE_API_KEY=
# BOOKING_CALENDAR_FALLBACK_URL=
