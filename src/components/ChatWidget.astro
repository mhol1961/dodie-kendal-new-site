---
/**
 * ChatWidget — floating chat affordance, bottom-right.
 *
 * Status: UI-only. The "Send" button on the quick-form posts to /api/contact
 * (which already accepts these shapes), so messages are captured today.
 *
 * TODO (Phase 9b): swap to GHL Conversations API when Dodie wires her
 * conversations app. See ADR-002 + GHL-INTEGRATION.md.
 */
const greeting = "Hi — I'm Dodie's assistant.";
const subgreeting = "Have a question about QHHT? Drop a quick note and I'll get back within 24-48 hours.";
---
<aside id="chat-widget" class="fixed bottom-5 right-5 z-50 md:bottom-7 md:right-7" aria-label="Chat with Dodie">
  <!-- Trigger button -->
  <button
    id="chat-toggle"
    type="button"
    aria-label="Open chat"
    aria-expanded="false"
    aria-controls="chat-panel"
    class="group flex h-14 w-14 items-center justify-center rounded-full bg-brand text-ink-inverse shadow-lg transition-all hover:bg-brand-hover hover:shadow-glow focus-visible:bg-brand-hover md:h-16 md:w-16"
  >
    <span class="sr-only">Open chat</span>
    <svg id="chat-icon-open" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <svg id="chat-icon-close" viewBox="0 0 24 24" class="hidden h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
    <!-- Pulse ring -->
    <span aria-hidden="true" class="pointer-events-none absolute inset-0 rounded-full ring-2 ring-brand/40 motion-safe:animate-ping"></span>
  </button>

  <!-- Panel -->
  <div
    id="chat-panel"
    role="dialog"
    aria-modal="false"
    aria-labelledby="chat-panel-title"
    hidden
    class="absolute bottom-20 right-0 w-[min(92vw,360px)] origin-bottom-right rounded-2xl border border-border-subtle bg-bg-raised shadow-[0_30px_60px_-15px_oklch(0.18_0.018_240_/_0.55)] overflow-hidden"
  >
    <!-- Header -->
    <header class="bg-aurora text-inverse px-5 py-4">
      <p id="chat-panel-title" class="font-display text-xl leading-tight">{greeting}</p>
      <p class="mt-1 text-sm text-inverse-muted leading-snug">{subgreeting}</p>
    </header>

    <!-- Quick contact form -->
    <form
      id="chat-form"
      action="/api/contact"
      method="POST"
      class="px-5 py-5 space-y-3"
      novalidate
    >
      <label class="block">
        <span class="sr-only">Your name</span>
        <input
          type="text"
          name="fullName"
          placeholder="Your name"
          required
          autocomplete="name"
          class="block w-full rounded-md border border-border-strong bg-bg-base px-3 py-2 text-sm text-ink placeholder:text-ink-muted focus:border-brand focus:outline-none"
        />
      </label>
      <label class="block">
        <span class="sr-only">Email</span>
        <input
          type="email"
          name="email"
          placeholder="Email"
          required
          autocomplete="email"
          class="block w-full rounded-md border border-border-strong bg-bg-base px-3 py-2 text-sm text-ink placeholder:text-ink-muted focus:border-brand focus:outline-none"
        />
      </label>
      <label class="block">
        <span class="sr-only">Message</span>
        <textarea
          name="message"
          rows="3"
          minlength="10"
          maxlength="600"
          required
          placeholder="What's on your mind?"
          class="block w-full rounded-md border border-border-strong bg-bg-base px-3 py-2 text-sm text-ink placeholder:text-ink-muted focus:border-brand focus:outline-none resize-none"
        ></textarea>
      </label>
      <!-- honeypot -->
      <input type="text" name="website" value="" tabindex="-1" aria-hidden="true" class="hidden" />
      <input type="hidden" name="consentTransactional" value="true" />
      <button
        type="submit"
        class="cta-glow inline-flex w-full items-center justify-center rounded-pill px-5 py-2.5 text-sm font-medium"
      >
        Send a note
      </button>
      <p id="chat-status" class="text-xs text-ink-muted" role="status" aria-live="polite"></p>
    </form>

    <!-- Fallback contact rail -->
    <footer class="border-t border-border-subtle bg-bg-sunken px-5 py-3 text-xs text-ink-muted">
      <p class="mb-1.5">Prefer direct?</p>
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <a href="tel:+15612016918" class="text-ink hover:text-brand">📞 1-561-201-6918</a>
        <a href="mailto:dodiekendall@gmail.com" class="text-ink hover:text-brand">✉ dodiekendall@gmail.com</a>
      </div>
    </footer>
  </div>
</aside>

<script is:inline>
  (function () {
    const toggle = document.getElementById('chat-toggle');
    const panel = document.getElementById('chat-panel');
    const iconOpen = document.getElementById('chat-icon-open');
    const iconClose = document.getElementById('chat-icon-close');
    const form = document.getElementById('chat-form');
    const status = document.getElementById('chat-status');
    if (!toggle || !panel || !iconOpen || !iconClose) return;

    const KEY = 'dk-chat-open';
    function setOpen(open) {
      panel.hidden = !open;
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close chat' : 'Open chat');
      iconOpen.classList.toggle('hidden', open);
      iconClose.classList.toggle('hidden', !open);
      try { sessionStorage.setItem(KEY, open ? '1' : '0'); } catch {}
      if (open) {
        const first = panel.querySelector('input, textarea');
        if (first) first.focus({ preventScroll: true });
      }
    }
    toggle.addEventListener('click', () => setOpen(panel.hidden));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.hidden) setOpen(false);
    });

    // Restore last state (panel closed on first visit, remembered after)
    try {
      if (sessionStorage.getItem(KEY) === '1') setOpen(true);
    } catch {}

    if (!form || !status) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const payload = {
        fullName: String(fd.get('fullName') ?? '').trim(),
        email: String(fd.get('email') ?? '').trim(),
        message: String(fd.get('message') ?? '').trim(),
        consentMarketing: false,
        consentTransactional: true,
        website: String(fd.get('website') ?? ''),
      };
      if (payload.fullName.length < 2 || !payload.email || payload.message.length < 10) {
        status.textContent = 'Add your name, email, and a short note (10+ chars).';
        status.className = 'text-xs text-error';
        return;
      }
      status.textContent = 'Sending…';
      status.className = 'text-xs text-ink-muted';
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (res.ok || res.status === 202) {
          status.textContent = 'Thank you — your note is on its way. Dodie writes back personally within 24-48 hours.';
          status.className = 'text-xs text-success';
          form.reset();
        } else {
          status.textContent = 'Something went wrong. You can also email dodiekendall@gmail.com directly.';
          status.className = 'text-xs text-error';
        }
      } catch (err) {
        status.textContent = 'Network error. Try emailing dodiekendall@gmail.com directly.';
        status.className = 'text-xs text-error';
      }
    });
  })();
</script>

<style>
  /* Smooth slide-in for the panel when shown */
  #chat-panel:not([hidden]) {
    animation: chat-enter 220ms cubic-bezier(0.2, 0.0, 0.0, 1) both;
  }
  @keyframes chat-enter {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    #chat-panel:not([hidden]) { animation: none; }
    #chat-toggle .motion-safe\:animate-ping { animation: none !important; }
  }
</style>
