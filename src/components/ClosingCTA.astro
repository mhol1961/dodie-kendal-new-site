---
/**
 * ClosingCTA — dark photographic backdrop, oversized italic question, single coral CTA.
 * Visual punctuation for the bottom of every page.
 */
interface Props {
  headlineLead?: string;
  headlineItalic?: string;
  headlineTail?: string;
  headline?: string;
  subhead?: string;
  cta: { label: string; href: string };
  trustLine?: string;
  /** Background poster image. Default: doorway-opens poster (threshold). */
  bgImage?: string;
  /** Background video. Default: doorway-opens.mp4 — threshold-opening metaphor. */
  bgVideo?: string;
  bgPosition?: string;
}

const {
  headlineLead,
  headlineItalic,
  headlineTail,
  headline,
  subhead,
  cta,
  trustLine,
  bgImage = '/video/doorway-opens-poster.jpg',
  bgVideo = '/video/doorway-opens.mp4',
  bgPosition = 'center',
} = Astro.props;
---
<section class="relative isolate overflow-hidden bg-bg-inverse-deeper py-28 md:py-36 text-inverse">
  <!-- Photographic background (poster + reduced-motion fallback) -->
  <img
    src={bgImage}
    alt=""
    aria-hidden="true"
    loading="lazy"
    class={`absolute inset-0 z-0 h-full w-full object-cover ${bgVideo ? 'motion-safe:opacity-0' : ''}`}
    style={`object-position: ${bgPosition}; filter: brightness(1.3) saturate(1.05);`}
  />
  {bgVideo && (
    <video
      src={bgVideo}
      poster={bgImage}
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
      class="absolute inset-0 z-0 h-full w-full object-cover motion-reduce:hidden"
      style={`object-position: ${bgPosition}; filter: brightness(1.3) saturate(1.05);`}
    />
  )}
  <!-- Dark gradient veil for legibility -->
  <div
    aria-hidden="true"
    class="absolute inset-0 z-0"
    style="background-image:
      radial-gradient(ellipse 75% 65% at 50% 50%, oklch(0.10 0.020 240 / 0.10) 0%, oklch(0.10 0.020 240 / 0.55) 85%),
      linear-gradient(180deg, oklch(0.10 0.020 240 / 0.22) 0%, oklch(0.05 0.020 240 / 0.62) 100%);"
  ></div>
  <!-- Coral horizon glow -->
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 z-0 h-1/2"
    style="background-image: radial-gradient(ellipse 70% 90% at 50% 100%, oklch(var(--brand-primary) / 0.32) 0%, transparent 70%);"
  ></div>

  <div class="relative z-10 container-default text-center" style="text-shadow: 0 2px 16px oklch(0.05 0.020 240 / 0.65);">
    {(headlineLead || headlineItalic || headlineTail) ? (
      <h2 class="mx-auto max-w-4xl font-display">
        {headlineLead && <span class="block">{headlineLead}</span>}
        {headlineItalic && (
          <span class="italic-accent block text-brand">{headlineItalic}</span>
        )}
        {headlineTail && <span class="block">{headlineTail}</span>}
      </h2>
    ) : (
      headline && <h2 class="mx-auto max-w-4xl font-display">{headline}</h2>
    )}

    {subhead && <p class="mx-auto mt-6 max-w-xl text-lg text-inverse-muted leading-relaxed">{subhead}</p>}

    <div class="mt-12 flex justify-center">
      <a
        href={cta.href}
        class="cta-glow inline-flex items-center justify-center rounded-pill px-10 py-4 text-lg font-medium"
      >
        {cta.label}
        <svg class="ml-3 h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    {trustLine && (
      <p class="mt-10 text-xs uppercase tracking-[0.24em] text-inverse-muted">{trustLine}</p>
    )}
  </div>
</section>
