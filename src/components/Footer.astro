      <ul class="space-y-2 text-ink-secondary">
        <li><a href="/privacy" class="hover:text-brand">Privacy Policy</a></li>
        <li><a href="/terms" class="hover:text-brand">Terms & Conditions</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-border-subtle">
    <div class="container-default py-6 text-xs text-ink-muted flex flex-col md:flex-row md:items-center md:justify-between gap-4">
