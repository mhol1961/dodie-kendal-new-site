---
/**
 * Footer — 4-column desktop, 1-column mobile, with the "not medical advice" disclaimer.
 * DESIGN.md §Layout: sunken bg, brand/site/contact/legal columns.
 */
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-border-subtle bg-bg-sunken">
  <div class="container-default grid grid-cols-1 gap-10 py-16 text-sm md:grid-cols-4 md:gap-8">
    <div class="md:col-span-1">
      <img
        src="/dodie-kendall-five-tattoo-stars-extra-deep-transparent.png"
        alt="Dodie Kendall"
        width="240"
        height="156"
        class="h-[72px] w-auto"
        loading="lazy"
      />
      <p class="mt-3 text-ink-secondary">
        QHHT Practitioner<br />Stuart, FL
      </p>
      <p class="mt-3 text-xs uppercase tracking-wider text-ink-muted">
        Quantum Healing Hypnosis Technique<br />in the Dolores Cannon lineage
      </p>
    </div>

    <nav aria-label="Footer — Site links">
      <h2 class="mb-3 text-base font-medium text-ink">Site</h2>
      <ul class="space-y-2 text-ink-secondary">
        <li><a href="/" class="hover:text-brand">Home</a></li>
        <li><a href="/about" class="hover:text-brand">About</a></li>
        <li><a href="/qhht" class="hover:text-brand">QHHT</a></li>
        <li><a href="/faq" class="hover:text-brand">FAQ</a></li>
        <li><a href="/insights" class="hover:text-brand">Insights</a></li>
      </ul>
    </nav>

    <div>
      <h2 class="mb-3 text-base font-medium text-ink">Contact</h2>
      <ul class="space-y-2 text-ink-secondary">
        <li><a href="tel:+15612016918" class="hover:text-brand">1-561-201-6918</a></li>
        <li><a href="mailto:dodiekendall@gmail.com" class="hover:text-brand">dodiekendall@gmail.com</a></li>
        <li class="pt-1">
          <a href="/book" class="inline-flex items-center rounded-pill bg-brand px-4 py-1.5 text-xs text-ink-inverse transition-colors hover:bg-brand-hover">
            Book a Session
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h2 class="mb-3 text-base font-medium text-ink">Legal</h2>
      <ul class="space-y-2 text-ink-secondary">
        <li><a href="/privacy" class="hover:text-brand">Privacy Policy</a></li>
        <li><a href="/terms" class="hover:text-brand">Terms &amp; Conditions</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-border-subtle">
    <div class="container-default flex flex-col gap-4 py-6 text-xs text-ink-muted md:flex-row md:items-center md:justify-between">
      <p>© {year} Dodie Kendall QHHT. All rights reserved.</p>
      <p class="max-w-2xl md:text-right">
        QHHT is a hypnosis modality intended for self-discovery and personal growth.
        This site does not provide medical, psychological, or therapeutic advice and is not a substitute for licensed care.
      </p>
    </div>
  </div>
</footer>
