---
/**
 * FounderSpotlight — asymmetric editorial. Real portrait, oversized italic display,
 * tight credential chips, single arrow CTA.
 */
interface Props {
  role: string;
  /** Plain headline text before italic accent. */
  headlineLead?: string;
  /** Italic emphasis phrase. */
  headlineItalic?: string;
  /** Plain headline text after italic accent. */
  headlineTail?: string;
  /** Fallback single-line headline. */
  headline?: string;
  body: string[];
  credentials?: string[];
  cta?: { label: string; href: string };
  photoSrc: string;
  photoAlt: string;
  /** Extra utility classes on the photo (e.g. object-position + scale for a tighter crop). */
  photoClass?: string;
}

const {
  role,
  headlineLead,
  headlineItalic,
  headlineTail,
  headline,
  body,
  credentials = [],
  cta,
  photoSrc,
  photoAlt,
  photoClass = '',
} = Astro.props;
---
<section class="section-y bg-bg-base">
  <div class="container-default">
    <div class="grid items-stretch gap-12 md:grid-cols-12 md:gap-16">
      <!-- Photo column — spans 5 of 12, with subtle linen-light video atmospherics behind -->
      <div class="md:col-span-5 lg:col-span-5">
        <div class="relative">
          <!-- Linen-light atmospheric video, very low opacity behind the photo -->
          <div aria-hidden="true" class="absolute -inset-10 -z-10 overflow-hidden rounded-3xl">
            <video
              src="/video/linen-light.mp4"
              poster="/video/linen-light-poster.jpg"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              class="absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-multiply motion-reduce:hidden"
            />
            <div class="absolute inset-0 bg-gradient-to-br from-teal/20 via-brand/15 to-transparent blur-2xl"></div>
          </div>
          <!-- Clip frame: rounded + overflow-hidden so a scaled photo crops cleanly -->
          <div class="relative overflow-hidden rounded-lg shadow-[0_30px_60px_-20px_oklch(0.18_0.018_240_/_0.4)]">
            <img
              src={photoSrc}
              alt={photoAlt}
              width="900"
              height="1100"
              loading="lazy"
              class:list={['w-full h-auto aspect-[9/11] object-cover', photoClass]}
            />
            <!-- Credential overlay strip on the photo -->
            <div class="absolute bottom-5 left-5 right-5 rounded-md bg-bg-base/95 backdrop-blur px-4 py-3 shadow-md border border-border-subtle">
              <p class="text-[10px] uppercase tracking-[0.22em] text-ink-muted">{role}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Copy column -->
      <div class="md:col-span-7 lg:col-span-6 lg:col-start-7 flex flex-col justify-center">
        <p class="text-xs uppercase tracking-[0.22em] text-brand">Meet Dodie</p>

        {(headlineLead || headlineItalic || headlineTail) ? (
          <h2 class="mt-4 font-display text-ink">
            {headlineLead && <span class="block">{headlineLead}</span>}
            {headlineItalic && (
              <span class="italic-accent block text-brand">{headlineItalic}</span>
            )}
            {headlineTail && <span class="block">{headlineTail}</span>}
          </h2>
        ) : (
          headline && <h2 class="mt-4 font-display text-ink">{headline}</h2>
        )}

        <div class="mt-7 max-w-prose space-y-5 text-lg leading-relaxed text-ink-secondary">
          {body.map((p) => <p>{p}</p>)}
        </div>

        {credentials.length > 0 && (
          <ul class="mt-8 flex flex-wrap gap-2.5">
            {credentials.map((c) => (
              <li class="rounded-pill border border-border-subtle bg-bg-raised px-4 py-1.5 text-xs uppercase tracking-[0.18em] text-ink-secondary">
                {c}
              </li>
            ))}
          </ul>
        )}

        {cta && (
          <div class="mt-10">
            <a
              href={cta.href}
              class="group inline-flex items-center gap-3 text-base font-medium text-ink hover:text-brand transition-colors"
            >
              <span class="underline decoration-1 underline-offset-[6px]">{cta.label}</span>
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
