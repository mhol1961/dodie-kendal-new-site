---
/**
 * Hero — cinematic editorial. Real photographic background, Fraunces display
 * with italic accent, single primary CTA. Photo overlay tuned for legibility.
 *
 * Variants:
 *   home    — full-bleed aurora photo + portrait inset + trust line
 *   about   — dark photographic background, text-led
 *   qhht    — dark photographic background, text-led
 *   insights — dark photographic background, text-led
 *   generic — light cream variant for utility pages
 */
interface Props {
  variant?: 'home' | 'about' | 'qhht' | 'insights' | 'generic';
  eyebrow?: string;
  headlineLead?: string;
  headlineItalic?: string;
  headlineTail?: string;
  headline?: string;
  subhead?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  trustLine?: string;
  portraitSrc?: string;
  portraitAlt?: string;
  /** Background image URL. Defaults per variant. */
  bgImage?: string;
  /** Object position for the bg image. Default: "center". */
  bgPosition?: string;
}

const {
  variant = 'home',
  eyebrow,
  headlineLead,
  headlineItalic,
  headlineTail,
  headline,
  subhead,
  primaryCta,
  secondaryCta,
  trustLine,
  portraitSrc,
  portraitAlt = '',
  bgImage,
  bgPosition = 'center',
} = Astro.props;

const isHome = variant === 'home';
const isDark = variant !== 'generic';

// Variant defaults for background photography
// (kept distinct from the in-page imagery so heros aren't repeating below)
const defaultBg: Record<string, string> = {
  home: '/photos/hero-aurora-real.jpg',
  about: '/photos/hero-milky-way.jpg',
  qhht: '/photos/hero-aurora-real.jpg',
  insights: '/photos/hero-milky-way.jpg',
};
const finalBg = bgImage ?? (isDark ? defaultBg[variant] : undefined);

const titleClass = isDark ? 'text-inverse' : 'text-ink';
const subClass = isDark ? 'text-inverse-muted' : 'text-ink-secondary';
const eyebrowClass = isDark ? 'text-teal-glow' : 'text-ink-muted';
---

<section
  class={`relative isolate overflow-hidden ${isDark ? 'bg-bg-inverse-deeper' : 'bg-sunrise'} ${isHome ? 'min-h-[90vh] flex items-center' : 'pt-24 pb-20 md:pt-32 md:pb-28'}`}
>
  <!-- Background photo -->
  {finalBg && (
    <>
      <img
        src={finalBg}
        alt=""
        aria-hidden="true"
        loading="eager"
        fetchpriority="high"
        class="absolute inset-0 z-0 h-full w-full object-cover"
        style={`object-position: ${bgPosition};`}
      />
      <!-- Dark vignette + bottom fade for legibility -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 z-0"
        style={
          isHome
            ? `background-image:
                linear-gradient(180deg, oklch(0.10 0.020 240 / 0.55) 0%, oklch(0.10 0.020 240 / 0.35) 40%, oklch(0.10 0.020 240 / 0.85) 100%),
                radial-gradient(ellipse 60% 50% at 18% 35%, oklch(0.10 0.020 240 / 0) 0%, oklch(0.10 0.020 240 / 0.55) 75%);`
            : `background-image:
                linear-gradient(180deg, oklch(0.10 0.020 240 / 0.7) 0%, oklch(0.10 0.020 240 / 0.55) 40%, oklch(0.10 0.020 240 / 0.85) 100%);`
        }
      ></div>
      <!-- Subtle horizon-glow tint at the bottom in brand color -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2 z-0"
        style="background-image: radial-gradient(ellipse 80% 100% at 50% 100%, oklch(var(--brand-primary) / 0.22) 0%, transparent 65%);"
      ></div>
    </>
  )}

  <div class={`relative z-10 container-default w-full ${isHome ? 'py-20 md:py-28' : ''}`}>
    <div class={isHome ? 'grid items-center gap-12 md:grid-cols-[1.1fr,0.9fr] lg:gap-16' : 'max-w-4xl'}>
      <div class={isHome ? 'order-2 md:order-1' : ''}>
        {eyebrow && (
          <p class={`text-xs uppercase tracking-[0.24em] mb-6 font-medium ${eyebrowClass}`}>
            {eyebrow}
          </p>
        )}

        {(headlineLead || headlineItalic || headlineTail) ? (
          <h1 class={`font-display ${titleClass}`}>
            {headlineLead && <span class="block">{headlineLead}</span>}
            {headlineItalic && (
              <span class="italic-accent block text-teal-glow">{headlineItalic}</span>
            )}
            {headlineTail && <span class="block">{headlineTail}</span>}
          </h1>
        ) : (
          headline && <h1 class={`font-display leading-tight ${titleClass}`}>{headline}</h1>
        )}

        {subhead && (
          <p class={`mt-7 max-w-xl text-lg md:text-xl leading-relaxed ${subClass}`}>{subhead}</p>
        )}

        {(primaryCta || secondaryCta) && (
          <div class="mt-10 flex flex-wrap items-center gap-5">
            {primaryCta && (
              <a
                href={primaryCta.href}
                class="cta-glow inline-flex items-center justify-center rounded-pill px-8 py-3.5 font-medium text-base"
              >
                {primaryCta.label}
                <svg class="ml-2 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14"/><path d="M12 5l7 7-7 7"/>
                </svg>
              </a>
            )}
            {secondaryCta && (
              <a
                href={secondaryCta.href}
                class={`inline-flex items-center gap-2 text-sm font-medium underline-offset-8 transition-colors ${isDark ? 'text-inverse hover:text-teal-glow' : 'text-ink hover:text-brand'}`}
              >
                <span class="underline decoration-1 underline-offset-[6px]">{secondaryCta.label}</span>
                <span aria-hidden="true">↗</span>
              </a>
            )}
          </div>
        )}

        {trustLine && (
          <p class={`mt-8 text-xs uppercase tracking-[0.22em] ${isDark ? 'text-inverse-muted' : 'text-ink-muted'}`}>
            {trustLine}
          </p>
        )}
      </div>

      {isHome && portraitSrc && (
        <div class="relative order-1 flex justify-center md:order-2 md:justify-end">
          <div class="relative">
            <!-- Soft halo behind portrait -->
            <span aria-hidden="true" class="absolute -inset-8 -z-10 rounded-full blur-3xl bg-gradient-to-br from-teal-glow/40 via-brand/30 to-transparent"></span>
            <img
              src={portraitSrc}
              alt={portraitAlt}
              width="540"
              height="675"
              loading="eager"
              fetchpriority="high"
              class="hero-portrait relative h-auto w-[260px] sm:w-[320px] md:w-[380px] lg:w-[440px] aspect-[4/5] object-cover object-top shadow-[0_30px_60px_-20px_oklch(0.05_0.02_240_/_0.8)]"
            />
            <!-- Floating credential chip -->
            <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 md:left-auto md:right-4 md:translate-x-0 rounded-pill bg-bg-inverse/85 backdrop-blur-md px-4 py-2 shadow-md border border-teal-glow/30">
              <p class="text-[10px] uppercase tracking-[0.22em] text-inverse-muted">QHHT · Dolores Cannon lineage</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Bottom-edge fade into the next section -->
  {isDark && (
    <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 h-20 z-10 bg-gradient-to-b from-transparent to-bg-inverse-deeper"></div>
  )}
</section>

<style>
  /* Organic blob mask for hero portrait */
  .hero-portrait {
    border-radius: 48% 52% 38% 62% / 40% 44% 56% 60%;
  }
</style>
