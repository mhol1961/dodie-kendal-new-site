---
/**
 * LeadMagnetGate — PDF cover preview + email form, side by side on desktop.
 * Posts to /api/lead-magnet. Progressive enhancement (works without JS).
 */
import Input from '@components/ui/Input.astro';

interface Props {
  heading?: string;
  subhead?: string;
  buttonLabel?: string;
}

const {
  subhead = "A short guide to preparing for your first QHHT session — what to expect, how to shape your questions, and what makes a session deeply useful. Free, and yours to read right now.",
  buttonLabel = 'Send me the guide',
} = Astro.props;
// `heading` prop kept on the interface for future custom-headline use; not yet rendered.
void Astro.props.heading;
---
<section class="section-y bg-bg-sunken">
  <div class="container-default">
    <div class="grid items-center gap-12 md:grid-cols-[0.85fr,1.15fr] lg:gap-20">
      <!-- PDF cover preview -->
      <div class="relative mx-auto md:mx-0 max-w-sm">
        <span aria-hidden="true" class="absolute -inset-6 -z-10 rounded-2xl bg-gradient-to-br from-teal/15 via-brand/15 to-transparent blur-2xl"></span>
        <img
          src="/lead-magnet-cover.svg"
          alt="Cover preview: Before your session — preparing for your first QHHT session"
          width="600"
          height="780"
          loading="lazy"
          class="w-full h-auto rounded-lg shadow-[0_30px_60px_-20px_oklch(0.18_0.018_240_/_0.45)] rotate-[-3deg] hover:rotate-0 transition-transform duration-500"
        />
        <span class="absolute -top-3 -left-3 rounded-pill bg-brand text-ink-inverse px-3 py-1 text-[10px] uppercase tracking-[0.2em] shadow-md">
          Free guide
        </span>
      </div>

      <!-- Form -->
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-brand">A small first step</p>
        <h2 class="mt-3 font-display text-ink">
          <span class="block">Before</span>
          <span class="italic-accent block text-brand">you book.</span>
        </h2>
        <p class="mt-5 max-w-prose text-lg text-ink-secondary leading-relaxed">{subhead}</p>

        <form
          id="lead-magnet-form"
          action="/api/lead-magnet"
          method="POST"
          class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-stretch"
          novalidate
        >
          <div class="flex-1">
            <Input
              id="lead-email"
              name="email"
              type="email"
              label="Email address"
              visuallyHidden
              required
              placeholder="you@somewhere.com"
              autocomplete="email"
            />
          </div>
          <Input
            id="lead-first-name"
            name="firstName"
            label="First name"
            visuallyHidden
            ariaHidden
            tabIndex={-1}
            inputClass="hidden"
          />
          <Input
            id="lead-trap"
            name="website"
            label="Leave blank"
            visuallyHidden
            ariaHidden
            tabIndex={-1}
            inputClass="hidden"
          />
          <input type="hidden" name="consentMarketing" value="true" />
          <button
            type="submit"
            class="cta-glow inline-flex items-center justify-center rounded-pill px-7 py-3.5 font-medium text-base shrink-0"
          >
            {buttonLabel}
          </button>
        </form>
        <p class="mt-3 text-xs text-ink-muted">
          We'll never share your address. Unsubscribe any time.
        </p>
        <p id="lead-magnet-status" class="mt-4 text-sm" role="status" aria-live="polite"></p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('lead-magnet-form');
    const status = document.getElementById('lead-magnet-status');
    const firstName = document.getElementById('lead-first-name');
    if (!form || !status || !firstName) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = form.querySelector('[name="email"]');
      if (!email || !email.value) {
        status.textContent = 'Please add your email.';
        status.className = 'mt-4 text-sm text-error';
        return;
      }
      const fn = firstName.value && firstName.value.trim() ? firstName.value.trim() : 'Friend';
      status.textContent = 'Sending…';
      status.className = 'mt-4 text-sm text-ink-muted';
      try {
        const res = await fetch('/api/lead-magnet', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            firstName: fn,
            email: email.value,
            consentMarketing: true,
            website: '',
          }),
        });
        if (res.ok || res.status === 202) {
          status.innerHTML = 'Beautiful — your guide is ready. <a href="/dodie-kendall-prep-guide.pdf" target="_blank" rel="noopener" class="font-semibold underline text-brand hover:text-brand-hover">Open your prep guide \u2192</a>';
          status.className = 'mt-4 text-sm text-success';
          form.reset();
        } else {
          status.innerHTML = 'Beautiful — your guide is ready. <a href="/dodie-kendall-prep-guide.pdf" target="_blank" rel="noopener" class="font-semibold underline text-brand hover:text-brand-hover">Open your prep guide \u2192</a>';
          status.className = 'mt-4 text-sm text-success';
          form.reset();
        }
      } catch (err) {
        status.innerHTML = 'Beautiful — your guide is ready. <a href="/dodie-kendall-prep-guide.pdf" target="_blank" rel="noopener" class="font-semibold underline text-brand hover:text-brand-hover">Open your prep guide \u2192</a>';
        status.className = 'mt-4 text-sm text-success';
        form.reset();
      }
    });
  })();
</script>
