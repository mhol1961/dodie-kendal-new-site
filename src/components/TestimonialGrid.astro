---
/**
 * TestimonialGrid — dark photographic section, featured oversized testimonial
 * + supporting cards. Editorial, not three identical cards.
 */
import { getCollection } from 'astro:content';

interface Props {
  heading?: string;
  headingItalic?: string;
  subhead?: string;
  supportingLimit?: number;
}

const {
  heading = 'What clients say',
  headingItalic = 'after a session.',
  subhead,
  supportingLimit = 2,
} = Astro.props;

const all = await getCollection('testimonials').catch(() => []);
const sorted = [...all].sort((a, b) => a.data.order - b.data.order);
const featured = sorted.find((t) => t.data.featured) ?? sorted[0];
const supporting = sorted
  .filter((t) => t.id !== featured?.id)
  .slice(0, supportingLimit);
---
{featured && (
  <section class="relative isolate overflow-hidden bg-bg-inverse-deeper text-inverse">
    <!-- Subtle aurora wash -->
    <div
      aria-hidden="true"
      class="absolute inset-0 z-0"
      style="background-image:
        radial-gradient(ellipse 70% 50% at 20% 30%, oklch(var(--brand-teal) / 0.32), transparent 60%),
        radial-gradient(ellipse 60% 50% at 85% 75%, oklch(var(--brand-primary) / 0.22), transparent 65%);"
    ></div>

    <div class="relative z-10 container-default py-24 md:py-32">
      <header class="mb-16 max-w-2xl">
        <p class="text-xs uppercase tracking-[0.24em] text-teal-glow">In their words</p>
        <h2 class="mt-3 font-display text-inverse">
          <span class="block">{heading}</span>
          {headingItalic && <span class="italic-accent block text-teal-glow">{headingItalic}</span>}
        </h2>
        {subhead && <p class="mt-5 text-lg text-inverse-muted leading-relaxed">{subhead}</p>}
      </header>

      <div class="grid gap-8 md:grid-cols-12 md:gap-10">
        <!-- Featured (oversized) — on a slightly raised dark panel -->
        <article class="md:col-span-7 relative rounded-lg border border-teal-glow/20 bg-bg-inverse/60 backdrop-blur-sm p-8 md:p-12 shadow-[0_30px_60px_-25px_oklch(0.05_0.02_240_/_0.7)]">
          <span aria-hidden="true" class="absolute -top-8 left-8 font-display text-7xl md:text-8xl leading-none text-brand">&ldquo;</span>
          <blockquote class="relative">
            <p class="font-serif text-2xl md:text-[1.625rem] leading-[1.45] text-inverse">
              {featured.data.quote}
            </p>
            <footer class="mt-8 flex items-center gap-4 border-t border-inverse-muted/20 pt-6">
              <span
                aria-hidden="true"
                class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full font-display text-lg text-inverse"
                style="background: linear-gradient(135deg, oklch(var(--brand-primary)) 0%, oklch(var(--brand-teal)) 100%);"
              >
                {(featured.data.author?.[0] ?? '·').toUpperCase()}
              </span>
              <div class="text-sm">
                <div class="font-medium text-inverse">{featured.data.author}</div>
                {(featured.data.location || featured.data.role) && (
                  <div class="text-inverse-muted">
                    {[featured.data.role, featured.data.location].filter(Boolean).join(' · ')}
                  </div>
                )}
              </div>
            </footer>
          </blockquote>
        </article>

        <!-- Supporting (vertical stack on desktop) — also on dark -->
        <div class="md:col-span-5 flex flex-col gap-6">
          {supporting.map((t) => (
            <article class="flex-1 rounded-lg border border-teal-glow/15 bg-bg-inverse/40 backdrop-blur-sm p-6 shadow-sm">
              <blockquote class="text-inverse-muted leading-relaxed">
                <span aria-hidden="true" class="font-display text-3xl leading-none text-brand">&ldquo;</span>
                <span>{t.data.quote}</span>
              </blockquote>
              <footer class="mt-5 flex items-center gap-3 border-t border-inverse-muted/15 pt-4 text-sm">
                <span
                  aria-hidden="true"
                  class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full font-display text-sm text-inverse"
                  style="background: linear-gradient(135deg, oklch(var(--brand-teal)) 0%, oklch(var(--brand-primary)) 100%);"
                >
                  {(t.data.author?.[0] ?? '·').toUpperCase()}
                </span>
                <div>
                  <div class="font-medium text-inverse">{t.data.author}</div>
                  {(t.data.location || t.data.role) && (
                    <div class="text-inverse-muted text-xs">
                      {[t.data.role, t.data.location].filter(Boolean).join(' · ')}
                    </div>
                  )}
                </div>
              </footer>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
)}
