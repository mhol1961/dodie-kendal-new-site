---
/**
 * TestimonialGrid — static grid of testimonial cards. NEVER a carousel.
 * Pulls from the testimonials content collection.
 */
import { getCollection } from 'astro:content';

interface Props {
  /** Max items to render. Default: all featured. */
  limit?: number;
  /** Only render featured testimonials. Default true. */
  featuredOnly?: boolean;
  heading?: string;
  subhead?: string;
}

const { limit, featuredOnly = true, heading = 'What clients say', subhead } = Astro.props;

const all = await getCollection('testimonials').catch(() => []);
const filtered = featuredOnly ? all.filter((t) => t.data.featured) : all;
const sorted = [...filtered].sort((a, b) => a.data.order - b.data.order);
const items = typeof limit === 'number' ? sorted.slice(0, limit) : sorted;

// Generate a soft hue per testimonial for the avatar orb (deterministic by index)
function avatarHue(idx: number): string {
  const hues = ['var(--brand-accent)', 'var(--brand-sage)', 'var(--brand-primary)'];
  return hues[idx % hues.length] ?? 'var(--brand-accent)';
}
---
<section class="section-y bg-bg-base">
  <div class="container-default">
    <header class="mb-12 max-w-2xl">
      <p class="text-xs uppercase tracking-wider text-ink-muted">In their words</p>
      <h2 class="mt-3 font-display">{heading}</h2>
      {subhead && <p class="mt-3 text-lg text-ink-secondary">{subhead}</p>}
    </header>

    {items.length === 0 ? (
      <p class="text-ink-muted">Testimonials are being added — check back soon.</p>
    ) : (
      <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" role="list">
        {items.map((t, idx) => (
          <li class="flex flex-col rounded-lg border border-border-subtle bg-bg-raised p-6 shadow-md">
            <blockquote class="flex-1 text-ink-secondary leading-relaxed">
              <span aria-hidden="true" class="font-display text-3xl leading-none text-accent">&ldquo;</span>
              <span>{t.data.quote}</span>
            </blockquote>
            <footer class="mt-5 flex items-center gap-3 border-t border-border-subtle pt-4">
              <span
                aria-hidden="true"
                class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full font-display text-base text-ink-inverse"
                style={`background-color: oklch(${avatarHue(idx)});`}
              >
                {(t.data.author?.[0] ?? '·').toUpperCase()}
              </span>
              <div class="text-sm">
                <div class="font-medium text-ink">{t.data.author}</div>
                {(t.data.location || t.data.role) && (
                  <div class="text-ink-muted">
                    {[t.data.role, t.data.location].filter(Boolean).join(' · ')}
                  </div>
                )}
              </div>
            </footer>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>
