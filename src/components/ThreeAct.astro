---
/**
 * ThreeAct — editorial three-step explainer on a dark photographic surface.
 * Each act gets an oversized teal-tinted numeral as typographic mass.
 */
interface Act {
  number: string;
  eyebrow: string;
  title: string;
  body: string;
}
interface Props {
  eyebrow?: string;
  heading: string;
  headingItalic?: string;
  subhead?: string;
  acts: Act[];
  ctaLabel?: string;
  ctaHref?: string;
  /** Background photo URL — defaults to milky-way for cosmic-warm depth. */
  bgImage?: string;
}

const {
  eyebrow,
  heading,
  headingItalic,
  subhead,
  acts,
  ctaLabel,
  ctaHref,
  bgImage = '/photos/hero-milky-way.jpg',
} = Astro.props;
---
<section class="relative isolate overflow-hidden bg-bg-inverse-deeper text-inverse">
  <!-- Background photo, dimmed for legibility -->
  <img
    src={bgImage}
    alt=""
    aria-hidden="true"
    loading="lazy"
    class="absolute inset-0 z-0 h-full w-full object-cover opacity-50"
  />
  <div
    aria-hidden="true"
    class="absolute inset-0 z-0"
    style="background-image:
      linear-gradient(180deg, oklch(0.10 0.020 240 / 0.85) 0%, oklch(0.10 0.020 240 / 0.7) 50%, oklch(0.10 0.020 240 / 0.95) 100%);"
  ></div>

  <div class="relative z-10 container-default py-24 md:py-32">
    <header class="mb-20 max-w-3xl">
      {eyebrow && <p class="text-xs uppercase tracking-[0.24em] text-teal-glow">{eyebrow}</p>}
      <h2 class="mt-3 font-display text-inverse">
        <span class="block">{heading}</span>
        {headingItalic && <span class="italic-accent block text-teal-glow">{headingItalic}</span>}
      </h2>
      {subhead && <p class="mt-6 max-w-2xl text-lg text-inverse-muted leading-relaxed">{subhead}</p>}
    </header>

    <div class="space-y-20 md:space-y-24">
      {acts.map((act, idx) => {
        const isOdd = idx % 2 === 1;
        return (
          <div class={`grid items-start gap-8 md:grid-cols-12 md:gap-12 ${isOdd ? 'md:[&>div:first-child]:order-2' : ''}`}>
            <!-- Numeral column -->
            <div class={`md:col-span-5 ${isOdd ? 'md:text-right' : ''}`}>
              <div class="relative inline-block">
                <p
                  class="font-display text-[clamp(8rem,18vw,16rem)] leading-[0.85] tracking-tighter text-teal-glow/25"
                  style="font-variation-settings: 'opsz' 144, 'wght' 300;"
                  aria-hidden="true"
                >
                  {act.number}
                </p>
                <p class="absolute top-6 left-0 md:left-auto md:top-6 text-xs uppercase tracking-[0.24em] text-brand">
                  {act.eyebrow}
                </p>
              </div>
            </div>

            <!-- Copy column -->
            <div class="md:col-span-7">
              <h3 class="font-serif text-3xl md:text-4xl text-inverse leading-tight">
                {act.title}
              </h3>
              <p class="mt-5 max-w-prose text-lg text-inverse-muted leading-relaxed">
                {act.body}
              </p>
            </div>
          </div>
        );
      })}
    </div>

    {ctaLabel && ctaHref && (
      <div class="mt-20 border-t border-teal-glow/15 pt-10">
        <a
          href={ctaHref}
          class="group inline-flex items-center gap-3 text-base font-medium text-teal-glow hover:text-inverse transition-colors"
        >
          <span class="underline decoration-1 underline-offset-[6px]">{ctaLabel}</span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>
    )}
  </div>
</section>
