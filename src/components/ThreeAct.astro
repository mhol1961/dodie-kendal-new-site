---
/**
 * ThreeAct — editorial three-step explainer (replaces the generic 3-up icon grid).
 * Asymmetric stacking, oversized numerals as typographic mass, SVG accent per act.
 */
interface Act {
  number: string;
  eyebrow: string;
  title: string;
  body: string;
}
interface Props {
  eyebrow?: string;
  heading: string;
  subhead?: string;
  acts: Act[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  eyebrow,
  heading,
  subhead,
  acts,
  ctaLabel,
  ctaHref,
} = Astro.props;
---
<section class="section-y bg-bg-base">
  <div class="container-default">
    <header class="mb-16 max-w-3xl">
      {eyebrow && <p class="text-xs uppercase tracking-[0.22em] text-ink-muted">{eyebrow}</p>}
      <h2 class="mt-3 font-display text-ink">
        {heading}
      </h2>
      {subhead && <p class="mt-5 max-w-2xl text-lg text-ink-secondary leading-relaxed">{subhead}</p>}
    </header>

    <div class="space-y-20 md:space-y-24">
      {acts.map((act, idx) => {
        const isOdd = idx % 2 === 1;
        return (
          <div class={`grid items-start gap-8 md:grid-cols-12 md:gap-12 ${isOdd ? 'md:[&>div:first-child]:order-2' : ''}`}>
            <!-- Numeral column -->
            <div class={`md:col-span-5 ${isOdd ? 'md:text-right' : ''}`}>
              <div class="relative inline-block">
                <p
                  class="font-display text-[clamp(7rem,15vw,12rem)] leading-none tracking-tighter text-brand/15"
                  style="font-variation-settings: 'opsz' 144, 'wght' 300;"
                  aria-hidden="true"
                >
                  {act.number}
                </p>
                <p class="text-xs uppercase tracking-[0.22em] text-brand absolute top-6 left-0 md:left-auto md:top-6">
                  {act.eyebrow}
                </p>
              </div>
            </div>

            <!-- Copy column -->
            <div class="md:col-span-7">
              <h3 class="font-serif text-3xl md:text-4xl text-ink leading-tight">
                {act.title}
              </h3>
              <p class="mt-5 max-w-prose text-lg text-ink-secondary leading-relaxed">
                {act.body}
              </p>
            </div>
          </div>
        );
      })}
    </div>

    {ctaLabel && ctaHref && (
      <div class="mt-20 border-t border-border-subtle pt-10">
        <a
          href={ctaHref}
          class="group inline-flex items-center gap-3 text-base font-medium text-ink hover:text-brand transition-colors"
        >
          <span class="underline decoration-1 underline-offset-[6px]">{ctaLabel}</span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>
    )}
  </div>
</section>
