---
/**
 * Accordion — native <details>/<summary> for FAQ. No JS required.
 * Keyboard-accessible by default. Respects prefers-reduced-motion via global rule.
 */
interface AccordionItemProps {
  question: string;
  answer: string;
  /** Render with this question expanded by default. */
  open?: boolean;
}

interface Props {
  items: AccordionItemProps[];
  /** Optional id prefix for unique anchor links. */
  idPrefix?: string;
}

const { items, idPrefix = 'faq' } = Astro.props;

function slugify(s: string) {
  return s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}
---
<ul class="space-y-3" role="list">
  {items.map((item, idx) => {
    const slug = slugify(item.question).slice(0, 60) || `q-${idx + 1}`;
    const id = `${idPrefix}-${slug}`;
    return (
      <li>
        <details id={id} class="group rounded-lg border border-border-subtle bg-bg-raised transition-colors duration-base ease-standard" open={item.open}>
          <summary
            class="flex cursor-pointer items-start justify-between gap-4 list-none px-5 py-4 font-medium text-ink hover:text-brand"
          >
            <span class="flex-1">{item.question}</span>
            <span
              aria-hidden="true"
              class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border-strong text-ink-secondary transition-transform duration-base ease-standard group-open:rotate-45"
            >+</span>
          </summary>
          <div class="px-5 pb-5 pt-1 text-ink-secondary leading-relaxed">
            {item.answer.split('\n').map((para) => (
              <p class="mb-3 last:mb-0">{para}</p>
            ))}
          </div>
        </details>
      </li>
    );
  })}
</ul>

<style is:global>
  /* Hide default arrow on summary in Safari */
  summary::-webkit-details-marker { display: none; }
  summary { list-style: none; }
</style>
