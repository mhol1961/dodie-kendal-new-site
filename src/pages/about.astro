---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import PullQuote from '@components/PullQuote.astro';
import SectionDivider from '@components/SectionDivider.astro';
import ClosingCTA from '@components/ClosingCTA.astro';
import { getSeo } from '@lib/seo';
import { breadcrumb } from '@lib/schema';

const SITE_URL = import.meta.env.SITE_URL || 'https://dodiekendall.com';

const seo = getSeo({
  path: '/about',
  title: 'About Dodie Kendall',
  description:
    "How Dodie Kendall — Florida-raised, Catholic-Pentecostal-then-universalist — came to QHHT and the simple truth that only love exists.",
});

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: `${SITE_URL}/about`,
  mainEntity: { '@id': `${SITE_URL}/#person` },
};

const schemas = [
  aboutPageSchema,
  breadcrumb([{ name: 'Home', href: '/' }, { name: 'About' }]),
];

interface BodyChapter {
  kind: 'body';
  num: string;
  era: string;
  title: string;
  body: string[];
  glyph?: 'sun' | 'seed' | 'thread';
}
interface QuoteChapter {
  kind: 'quote';
  text: string;
}
type Item = BodyChapter | QuoteChapter;

const chapters: Item[] = [
  {
    kind: 'body',
    num: '01',
    era: 'Childhood — South Florida',
    title: 'The early years: ritual and questioning.',
    body: [
      "I am a native Floridian, raised in the tradition of the Catholic Church. From baptism and CCD to Catholic High School, the structure of religion was always around me. Yet, inside, I felt a disconnect. The ceremonies often felt intimidating rather than comforting, and as a young woman, I struggled to find the spiritual side of the actions I was performing.",
      "By my teens, I felt that church was simply for \"old people,\" and I stepped away to find my own way.",
    ],
    glyph: 'sun',
  },
  {
    kind: 'body',
    num: '02',
    era: 'Young adulthood — A new question',
    title: 'The search for something more.',
    body: [
      "While teaching aerobics and navigating the typical unwise choices of youth, I met a young woman whose vibrant faith challenged my perceptions. She didn't fit my \"old person\" mold of religion. Following her lead, I found myself in a non-denominational Pentecostal church, witnessing things that both perplexed and intrigued me — tongues, dancing, and a raw, supernatural energy I hadn't seen before.",
      "When asked the pivotal question — \"Dodie, do you know where you will go if you died tonight?\" — I realized I didn't have an answer. Motivated by a mix of curiosity and the fear of eternal damnation, I invited Jesus into my heart. It was a time of high energy and \"Whooo hooo!\" moments, but it also brought my first real lesson in the complexity of healing.",
    ],
    glyph: 'seed',
  },
  {
    kind: 'quote',
    text:
      "The promise was that the prayer of faith shall heal the sick. My friend and I went to lay hands on him. His physical body did not heal; he passed on to the next dimension.",
  },
  {
    kind: 'body',
    num: '03',
    era: 'The questioning years',
    title: 'A lesson in healing and transition.',
    body: [
      "I remember vividly when my brother's friend was in the ICU with acute leukemia. Armed with the promise of scripture, I prayed. He did not heal. I was told he was in heaven because of our prayers, but this was a seed of doubt. A lot of things began to feel out of alignment.",
      "I eventually left that church, but for years I carried the heavy belief that there was only \"one way\" to God.",
    ],
    glyph: 'thread',
  },
  {
    kind: 'body',
    num: '04',
    era: 'The widening',
    title: 'The shift: from fear to universal love.',
    body: [
      "Life happened. Through the ups and downs, I met beautiful, compassionate people from all walks of life — Buddhists, Muslims, Hindus, and many others. The idea that a loving God would send these souls to eternal damnation no longer resonated with my own soul.",
      "I chose to abandon that belief system for a new perspective: God is Energy. A loving, universal energy that encompasses all humans. In this space, only love exists, and free will is the greatest gift we have been given.",
    ],
    glyph: 'sun',
  },
  { kind: 'quote', text: "Only love exists." },
  {
    kind: 'body',
    num: '05',
    era: 'The arrival',
    title: 'Discovering the Sacred Technology.',
    body: [
      "I always held onto the scripture that we would do \"greater things\" than those who came before us. I knew we were incredible, sacred, and intelligent beings — but I didn't know how to tap into that potential until I was divinely introduced to Dolores Cannon's QHHT.",
      "The moment I discovered it, I had an inner knowing. This was the modality that explained everything. It was the bridge between my spiritual past and the healing future I was meant to facilitate.",
    ],
    glyph: 'seed',
  },
  {
    kind: 'body',
    num: '06',
    era: 'Today',
    title: 'The invitation.',
    body: [
      "Today, I am here to help you experience the Creator's gift: the connection to your Higher Self, the Subconscious, the Holy Spirit. Whatever name you choose to give it, it is the voice that guides us.",
      "I am the invitation, not the insistence. I speak from love, not urgency. Healing flows through me, not from me.",
      "My life has changed in beautiful ways because I have learned to trust this path and receive the insights needed to live life to the fullest. This Sacred Technology is a gift from the Creator of the Universe that cares about every detail of your current lifetime — and every other lifetime you have ever lived.",
      "Only love exists. I invite you to allow me to guide you today, so you can finally receive the messages your Higher Self has been waiting for you to hear.",
    ],
    glyph: 'thread',
  },
];

// Mid-page photo break point — render the portrait between chapter 04 and chapter 05
function shouldBreakAfter(idx: number): boolean {
  // After the "Only love exists" pull quote
  const item = chapters[idx];
  return item?.kind === 'quote' && item.text === 'Only love exists.';
}
---
<Base seo={seo} schemas={schemas}>
  <Hero
    variant="about"
    eyebrow="About Dodie"
    headlineLead="The path to purpose —"
    headlineItalic="from tradition"
    headlineTail="to transcendence."
    subhead="A native Floridian raised Catholic, who walked through Pentecostal Christianity, then exposure to Buddhists, Muslims, and Hindus, and arrived at the simple truth that only love exists."
    portraitSrc=""
  />

  <!-- Identity strip — credentials in a clean band -->
  <section class="bg-bg-sunken py-8">
    <div class="container-default grid grid-cols-2 gap-4 md:grid-cols-4">
      <div>
        <p class="text-[10px] uppercase tracking-[0.22em] text-ink-muted">Lineage</p>
        <p class="mt-1 font-display text-xl text-ink">Dolores Cannon</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.22em] text-ink-muted">Based in</p>
        <p class="mt-1 font-display text-xl text-ink">Palm Beach FL</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.22em] text-ink-muted">Sessions</p>
        <p class="mt-1 font-display text-xl text-ink">5 hours · $300</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.22em] text-ink-muted">Format</p>
        <p class="mt-1 font-display text-xl text-ink">In-person · Remote</p>
      </div>
    </div>
  </section>

  <!-- Story prose with chapter dividers + mid-page photo break -->
  <section class="section-y bg-bg-base">
    <div class="container-prose">
      {chapters.map((item, idx) => (
        <>
          {item.kind === 'quote' ? (
            <PullQuote quote={item.text} />
          ) : (
            <article class="reveal-on-scroll mb-12">
              <div class="mb-5 flex flex-wrap items-baseline gap-4">
                <span class="font-display text-5xl text-brand/40 leading-none">{item.num}</span>
                <p class="text-[10px] uppercase tracking-[0.22em] text-ink-muted">{item.era}</p>
              </div>
              <h2 class="font-display text-3xl md:text-4xl text-ink">{item.title}</h2>
              <div class="mt-6 space-y-5 text-lg leading-relaxed text-ink-secondary">
                {item.body.map((p) => <p>{p}</p>)}
              </div>
              {item.glyph && idx < chapters.length - 1 && (
                <SectionDivider glyph={item.glyph} color="muted" />
              )}
            </article>
          )}
          {shouldBreakAfter(idx) && (
            <figure class="my-16 -mx-4 sm:-mx-6 md:-mx-12">
              <div class="relative">
                <span aria-hidden="true" class="absolute -inset-4 -z-10 rounded-lg bg-gradient-to-br from-teal/15 via-brand/15 to-transparent blur-3xl"></span>
                <img
                  src="/dodie-portrait.jpg"
                  alt="Dodie Kendall portrait"
                  loading="lazy"
                  class="w-full aspect-[16/10] object-cover object-top rounded-lg shadow-[0_30px_60px_-20px_oklch(0.18_0.018_240_/_0.4)]"
                />
              </div>
              <figcaption class="mt-3 text-center text-xs uppercase tracking-[0.22em] text-ink-muted">
                South Florida · Practicing since the discovery
              </figcaption>
            </figure>
          )}
        </>
      ))}
    </div>
  </section>

  <ClosingCTA
    headlineLead="Your Higher Self"
    headlineItalic="is already speaking."
    headlineTail="Are you ready to listen?"
    subhead="One 5-hour conversation with the deepest part of you. Held with confidentiality, recorded for you to keep."
    cta={{ label: 'Book a Session', href: '/book' }}
    trustLine="$300 · 5 hours · Palm Beach FL or remote via Zoom"
  />
</Base>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 600ms ease, transform 600ms ease;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll { opacity: 1; transform: none; transition: none; }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.reveal-on-scroll').forEach((el) => el.classList.add('is-visible'));
      return;
    }
    if (!('IntersectionObserver' in window)) {
      document.querySelectorAll('.reveal-on-scroll').forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      }),
      { rootMargin: '0px 0px -80px 0px', threshold: 0.05 }
    );
    document.querySelectorAll('.reveal-on-scroll').forEach((el) => io.observe(el));
  })();
</script>
