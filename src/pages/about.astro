---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import PullQuote from '@components/PullQuote.astro';
import AboutChapter from '@components/AboutChapter.astro';
import ClosingCTA from '@components/ClosingCTA.astro';
import { getSeo } from '@lib/seo';
import { breadcrumb } from '@lib/schema';

const SITE_URL = import.meta.env.SITE_URL || 'https://dodiekendall.com';

// Copy: Dodie's own bio draft (emailed 2026-07-14), replacing the earlier
// religion-heavy chapter narrative she asked to remove (2026-06-02 call).
// The new arc is: a decades-long personal search → understanding us as
// multidimensional energy → discovering Dolores Cannon's QHHT → the work
// today. No denominational specifics per her request. Wording is kept close
// to her draft; era/takeaway/eyebrow scaffolding lines are ours.
const seo = getSeo({
  path: '/about',
  title: 'About Dodie Kendall',
  description:
    "Dodie Kendall — a native Floridian QHHT practitioner whose decades-long search for meaning led her to Dolores Cannon's Quantum Healing Hypnosis Technique.",
});

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: `${SITE_URL}/about`,
  mainEntity: { '@id': `${SITE_URL}/#person` },
};
const schemas = [
  aboutPageSchema,
  breadcrumb([{ name: 'Home', href: '/' }, { name: 'About' }]),
];

const principles = [
  {
    title: 'A mirror, not a guru.',
    body: "I offer a path; I don't walk it for you.",
  },
  {
    title: 'I trust your timing.',
    body: 'Every soul finds its own moment, and I meet you exactly where you are.',
  },
  {
    title: 'Love, not urgency.',
    body: "There's no pressure here — only invitation.",
  },
  {
    title: 'Healing flows through me, not from me.',
    body: "You are the one doing the healing. I'm simply here to hold space for it.",
  },
];
---
<Base seo={seo} schemas={schemas}>
  <!-- HERO — tropical Florida light -->
  <Hero
    variant="about"
    eyebrow="About Dodie"
    headlineLead="The path that"
    headlineItalic="brought me"
    headlineTail="here."
    subhead="I'm a QHHT practitioner — but before the work I do now, let me tell you about the path that led me to it. If you're reading this, chances are you're on a search of your own. I don't believe our paths crossing is an accident."
    bgImage="/video/about-tropical-light-poster.jpg"
    bgVideo="/video/about-tropical-light.mp4"
  />

  <!-- IDENTITY STRIP — dark band -->
  <section class="bg-bg-inverse-deeper py-10 text-inverse border-y border-teal-glow/15">
    <div class="container-default grid grid-cols-2 gap-6 md:grid-cols-4">
      <div>
        <p class="text-[10px] uppercase tracking-[0.24em] text-brand">Lineage</p>
        <p class="mt-2 font-display text-xl text-inverse">Dolores Cannon</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.24em] text-brand">Based in</p>
        <p class="mt-2 font-display text-xl text-inverse">Stuart, FL</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.24em] text-brand">Sessions</p>
        <p class="mt-2 font-display text-xl text-inverse">Approximately 5 hrs</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.24em] text-brand">Format</p>
        <p class="mt-2 font-display text-xl text-inverse">In-person</p>
      </div>
    </div>
  </section>

  <!-- CH 01 + 02 -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl space-y-24">
      <AboutChapter
        num="01"
        era="Where I started · South Florida"
        title="Where I started."
        takeaway="Underneath the career and the daily busyness, a quieter question was always running."
        body={[
          "I was born in Fort Lauderdale and raised in Pompano Beach. I grew up with a strong sense of tradition and faith — and, like so many of us, I spent years inside a belief system that had been handed down to me rather than one I'd chosen for myself.",
          "As a young woman I moved from Broward County to Palm Beach County and built the foundation of my adult life: teaching aerobics, then moving into mortgage, title, and real estate, where I spent decades building a career I'm proud of. But underneath it all, a quieter question kept running — who is the Creator of this universe, really? And who am I in relation to that?",
        ]}
      />

      <AboutChapter
        num="02"
        era="The searching years"
        title="A search that took decades."
        takeaway="I tried, sincerely, to live inside the frameworks I was given. Pieces of them never quite fit."
        body={[
          "That question sent me on a long, winding journey. I explored different communities and teachings, different ways people made sense of the soul and the meaning of our lives here on Earth. I watched how people lived out their beliefs — the struggles and the joys, the certainty and the doubt — and I tried, sincerely, to live inside the frameworks I was given.",
          "But pieces of it never quite fit. So I kept searching. I married the love of my life, raised two children, built a career, and traveled — experiencing different cultures and different ways of understanding the sacred. Through it all, the search never stopped.",
        ]}
      />
    </div>
  </section>

  <PullQuote variant="dark" quote="Through it all, the search never stopped." />

  <!-- CH 03 — What I found -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl">
      <AboutChapter
        num="03"
        era="The click"
        title="What I found."
        takeaway="Everything I'd been searching for came into focus. I knew this was what I was born to do."
        body={[
          "Eventually, it began to click. I came to understand us as multidimensional beings — that at our essence we are energy: patterns of light, consciousness, and information, moving through what I've come to think of as “Earth school.” A place to learn, to evolve, to create, and to grow.",
          "I found that quantum physics offers a beautiful, tangible way of understanding these same truths at the smallest levels of reality — that separation is an illusion, and that we are all part of one vast, indivisible field of consciousness. When I discovered QHHT, the work pioneered by Dolores Cannon, everything came into focus. I knew, immediately and completely, that this was what I was born to do.",
        ]}
      />
    </div>
  </section>

  <PullQuote variant="dark" quote="I was born to do this!" />

  <!-- ONE LIGHT — Rumi lanterns, reframed to oneness (not tradition-divisions) -->
  <section class="bg-bg-inverse-deeper">
    <div class="container-default py-16 md:py-20">
      <header class="mb-10 max-w-2xl">
        <p class="text-xs uppercase tracking-[0.24em] text-brand">One light</p>
        <h2 class="mt-3 font-display text-inverse">
          <span class="block">Different lamps.</span>
          <span class="italic-accent block text-brand">Same light.</span>
        </h2>
        <p class="mt-5 text-lg text-inverse-muted leading-relaxed">
          A way of seeing I kept arriving at on my own — that what looks like separation is only the surface, and the light underneath is one.
        </p>
      </header>
      <figure class="relative mx-auto max-w-4xl overflow-hidden rounded-lg shadow-[0_30px_60px_-20px_oklch(0.05_0.02_240_/_0.7)]">
        <img
          src="/dodie/rumi-lamps.jpg"
          alt="Colorful paper lanterns glowing against a dark sky."
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <!-- CH 04 — What I do now -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl">
      <AboutChapter
        num="04"
        era="The arrival"
        title="What I do now."
        takeaway="It isn't a career change so much as an arrival."
        body={[
          "After years as a new construction sales consultant (2013–2023), and later as a residential realtor, I made the decision to devote myself fully to QHHT. It wasn't so much a career change as an arrival — the place all those years of searching, working, and living had quietly been leading me.",
          "As a practitioner, my role is simple, and I hold it humbly.",
        ]}
        image={{
          src: "/dodie/dodie-standing-pink.jpg",
          alt: "Dodie Kendall standing in a soft pink dress with a calm, contemplative expression.",
        }}
        imageRight
      />

      <!-- Four principles — static grid (no carousel) -->
      <div class="mt-14 grid gap-5 sm:grid-cols-2">
        {principles.map((p) => (
          <div class="rounded-lg border border-border-subtle bg-bg-raised p-6 shadow-sm">
            <p class="font-display text-xl text-ink leading-snug">{p.title}</p>
            <p class="mt-2 text-ink-secondary leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PullQuote variant="dark" quote="I am a mirror, not a guru. I offer a path; I don't walk it for you." />

  <!-- NATURE BREAK — red cardinal (a recurring 'sign' motif in Dodie's world) -->
  <section class="bg-bg-inverse-deeper">
    <div class="relative overflow-hidden">
      <img
        src="/photos/about-red-cardinal.jpg"
        alt="A red cardinal perched on a flowering branch in soft morning light."
        loading="lazy"
        class="w-full h-auto aspect-[21/9] object-cover"
      />
      <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-bg-inverse-deeper/70 via-transparent to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0">
        <div class="container-default pb-8 md:pb-12">
          <p class="text-xs uppercase tracking-[0.24em] text-brand">A sign, arriving right on time</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CH 05 — Life outside the work -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl">
      <AboutChapter
        num="05"
        era="Away from the work"
        title="My life outside this work."
        takeaway="I've been where you might be — searching, unsure, wondering if there's more."
        body={[
          "I'm married to my best friend. This is my second marriage, and together we've built a beautifully blended family — my two children, who were already grown and on their own when we met, and his two, who lived with us as they grew up. Between us, we've now been blessed with three grandchildren, who bring more joy into my life than I ever could have imagined.",
          "My own journey — the searching, the blending, the years of questioning — is part of why I do this work with so much care. I've been where you might be: searching, unsure, wondering if there's more. I believe there is.",
        ]}
        image={{
          src: "/dodie/beach-evening.jpg",
          alt: "Dodie Kendall on a Florida beach in the soft light of evening.",
        }}
      />
    </div>
  </section>

  <!-- WHY I DO THIS WORK — healing-tree promise + signature -->
  <section class="bg-bg-sunken py-20 md:py-24">
    <div class="container-default grid items-center gap-10 md:grid-cols-[1fr,1.1fr] lg:gap-16">
      <figure class="mx-auto max-w-md md:max-w-none">
        <img
          src="/dodie/healing-tree.jpg"
          alt="Watercolor tree of life with the words: Your body's ability to heal is greater than anyone has permitted you to believe."
          class="w-full h-auto rounded-lg shadow-md"
          loading="lazy"
        />
      </figure>
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-brand">Why I do this work</p>
        <h2 class="mt-3 font-display text-ink">
          <span class="block">You are not broken.</span>
          <span class="italic-accent block text-brand">You are remembering.</span>
        </h2>
        <p class="mt-5 max-w-prose text-lg text-ink-secondary leading-relaxed">
          We are all connected — points of light, patterns of energy and information, woven into one vast web of consciousness. My hope is that through this work, you come away not just with answers, but with a deeper awareness of your own multidimensional nature, and the peace that comes with remembering who you really are.
        </p>
        <p class="mt-6 max-w-prose text-lg text-ink-secondary leading-relaxed">
          I'd be honored to walk alongside you as you explore your own path.
        </p>
        <p class="mt-6 font-serif text-2xl text-ink italic-accent">— Dodie</p>
      </div>
    </div>
  </section>

  <!-- CLOSING — doorway video -->
  <ClosingCTA
    headlineLead="Your Higher Self"
    headlineItalic="is already speaking."
    headlineTail="Are you ready to listen?"
    subhead="A conversation with the deepest part of you. Held with confidentiality, recorded for you to keep."
    cta={{ label: 'Book a Session', href: '/book' }}
    trustLine="In-person sessions · Stuart, FL"
  />
</Base>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 600ms ease, transform 600ms ease;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll { opacity: 1; transform: none; transition: none; }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.reveal-on-scroll').forEach((el) => el.classList.add('is-visible'));
      return;
    }
    if (!('IntersectionObserver' in window)) {
      document.querySelectorAll('.reveal-on-scroll').forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      }),
      { rootMargin: '0px 0px -80px 0px', threshold: 0.05 }
    );
    document.querySelectorAll('.reveal-on-scroll').forEach((el) => io.observe(el));
  })();
</script>
