---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import PullQuote from '@components/PullQuote.astro';
import AboutChapter from '@components/AboutChapter.astro';
import ClosingCTA from '@components/ClosingCTA.astro';
import { getSeo } from '@lib/seo';
import { breadcrumb } from '@lib/schema';

const SITE_URL = import.meta.env.SITE_URL || 'https://dodiekendall.com';

// [NEEDS COPY] Per 2026-06-02 call: Dodie is rewriting her bio. She asked
// for all religion references removed across the site. The heavy chapter
// content below (Catholic upbringing, Pentecostal years, Buddhist/Muslim/
// Hindu openings, "only love exists" resolution) is left intact for now —
// gutting it without her replacement leaves the page hollow. The hero
// subhead, SEO description, identity strip, and closing CTA below have
// been softened to remove religion-line specifics while we wait for her
// new draft.
const seo = getSeo({
  path: '/about',
  title: 'About Dodie Kendall',
  description:
    "Dodie Kendall — a native Floridian QHHT practitioner who came home to the simple truth that only love exists.",
});

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: `${SITE_URL}/about`,
  mainEntity: { '@id': `${SITE_URL}/#person` },
};
const schemas = [
  aboutPageSchema,
  breadcrumb([{ name: 'Home', href: '/' }, { name: 'About' }]),
];
---
<Base seo={seo} schemas={schemas}>
  <!-- HERO — tropical Florida sunrise video -->
  <Hero
    variant="about"
    eyebrow="About Dodie"
    headlineLead="The path to purpose —"
    headlineItalic="from tradition"
    headlineTail="to transcendence."
    subhead="A native Floridian who walked a long path through many traditions and arrived at the simple truth that only love exists."
    bgImage="/video/about-tropical-light-poster.jpg"
    bgVideo="/video/about-tropical-light.mp4"
  />

  <!-- IDENTITY STRIP — dark band -->
  <section class="bg-bg-inverse-deeper py-10 text-inverse border-y border-teal-glow/15">
    <div class="container-default grid grid-cols-2 gap-6 md:grid-cols-4">
      <div>
        <p class="text-[10px] uppercase tracking-[0.24em] text-brand">Lineage</p>
        <p class="mt-2 font-display text-xl text-inverse">Dolores Cannon</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.24em] text-brand">Based in</p>
        <p class="mt-2 font-display text-xl text-inverse">Stuart, FL</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.24em] text-brand">Sessions</p>
        <p class="mt-2 font-display text-xl text-inverse">About 5 hrs</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-[0.24em] text-brand">Format</p>
        <p class="mt-2 font-display text-xl text-inverse">In-person</p>
      </div>
    </div>
  </section>

  <!-- CH 01 + 02 — scan-friendly chapter component, with image on Ch 01 -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl space-y-24">
      <AboutChapter
        num="01"
        era="Childhood · South Florida"
        title="The early years — ritual and questioning."
        takeaway="The structure was always around me. The disconnect was always inside me."
        body={[
          "I was raised Catholic in South Florida — baptism, CCD, Catholic High School, the full structure. From the outside it looked complete. From the inside, the ceremonies felt more intimidating than comforting.",
          "By my teens I felt church was for old people, and I stepped away to find my own way.",
        ]}
        image={{
          src: "/dodie/beach-evening.jpg",
          alt: "South Florida evening — palms over the water",
        }}
        imageRight
      />

      <AboutChapter
        num="02"
        era="Young adulthood · A new question"
        title="The search for something more."
        takeaway="Whoo-hoo moments — and my first real lesson in the complexity of healing."
        body={[
          "Teaching aerobics and making the usual unwise choices of youth, I met a young woman whose vibrant faith challenged what I thought religion was. She wasn't an old person. I followed her into a non-denominational Pentecostal church.",
          "What I saw there was new to me — tongues, dancing, a raw supernatural energy. And then the question that changed everything: 'Dodie, do you know where you'd go if you died tonight?'",
        ]}
      />
    </div>
  </section>

  <!-- SHORT pull quote — replaces the long "prayer of faith" paragraph -->
  <PullQuote
    variant="dark"
    quote="Where would you go if you died tonight?"
  />

  <!-- CH 03 — scan-friendly format continues -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl">
      <AboutChapter
        num="03"
        era="The questioning years"
        title="A lesson in healing — and its limits."
        takeaway="I prayed with the promise of scripture. He did not heal. A seed of doubt."
        body={[
          "My brother's friend was in the ICU with acute leukemia. The promise was that the prayer of faith would heal the sick. My friend and I laid hands on him. His body did not heal — he passed on.",
          "I was told he was in heaven because of our prayers. But something in me felt out of alignment. I eventually left that church, but carried for years the heavy belief that there was only one way to God.",
        ]}
      />
    </div>
  </section>

  <!-- DARK IMAGE BREAK — Santa Teresa sunset -->
  <section class="bg-bg-inverse-deeper">
    <div class="relative">
      <img
        src="/dodie/santa-teresa-sunset.jpg"
        alt="A Florida sunset glowing through tropical foliage — from Dodie's view"
        class="w-full h-auto aspect-[16/9] object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 flex items-center justify-end">
        <div class="container-default flex justify-end">
          <div class="max-w-sm rounded-lg bg-bg-inverse/70 backdrop-blur-sm p-6 md:p-8 border border-teal-glow/20">
            <p class="text-[10px] uppercase tracking-[0.24em] text-brand mb-3">Home</p>
            <p class="font-serif text-xl md:text-2xl text-inverse leading-snug">
              South Florida light.<br/>
              <em class="italic-accent text-brand">My whole story unfolds here.</em>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CH 04 -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl">
      <AboutChapter
        num="04"
        era="The widening"
        title="From fear to universal love."
        takeaway="The idea that a loving God would condemn good souls no longer rang true."
        body={[
          "Life happened. I met beautiful, compassionate people from every walk — Buddhists, Muslims, Hindus, atheists. The idea of a loving God damning these souls stopped making sense.",
          "I chose a new perspective: God is energy. A loving universal energy that holds all of us. In that space, only love exists, and free will is the greatest gift we have.",
        ]}
      />
    </div>
  </section>

  <!-- DARK PULL QUOTE — kept (this one is short and perfect) -->
  <PullQuote variant="dark" quote="Only love exists." />

  <!-- RUMI LAMPS — the thesis image -->
  <section class="bg-bg-inverse-deeper">
    <div class="container-default py-16 md:py-20">
      <header class="mb-10 max-w-2xl">
        <p class="text-xs uppercase tracking-[0.24em] text-brand">A line that opened the door</p>
        <h2 class="mt-3 font-display text-inverse">
          <span class="block">Different lamps.</span>
          <span class="italic-accent block text-brand">Same light.</span>
        </h2>
        <p class="mt-5 text-lg text-inverse-muted leading-relaxed">
          A quote that captured what I was already finding inside myself — that the divisions between traditions are surface, and the light underneath is one.
        </p>
      </header>
      <figure class="relative mx-auto max-w-4xl overflow-hidden rounded-lg shadow-[0_30px_60px_-20px_oklch(0.05_0.02_240_/_0.7)]">
        <img
          src="/dodie/rumi-lamps.jpg"
          alt="Colorful paper lanterns with Rumi's quote: 'The lamps are different, but the light is the same.'"
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <!-- CH 05 -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl">
      <AboutChapter
        num="05"
        era="The arrival"
        title="Discovering the Sacred Technology."
        takeaway="The bridge between my spiritual past and the work I was meant to do."
        body={[
          "I'd always held onto the scripture that we would do 'greater things' than those who came before — but I never knew how. Then I was introduced to Dolores Cannon's QHHT.",
          "The moment I discovered it, I had an inner knowing. This was the modality that explained everything. It was the bridge I'd been waiting for.",
        ]}
      />
    </div>
  </section>

  <!-- DARK VIDEO BREAK — Florida sunrise -->
  <section class="bg-bg-inverse-deeper">
    <div class="relative overflow-hidden">
      <img
        src="/video/florida-sunrise-poster.jpg"
        alt="Florida coast at sunrise — palm fronds framing the horizon"
        loading="lazy"
        class="w-full h-auto aspect-[21/9] object-cover motion-safe:opacity-0"
      />
      <video
        src="/video/florida-sunrise.mp4"
        poster="/video/florida-sunrise-poster.jpg"
        autoplay muted loop playsinline preload="metadata"
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover motion-reduce:hidden"
      />
      <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-bg-inverse-deeper/80 via-transparent to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0">
        <div class="container-default pb-8 md:pb-12">
          <p class="text-xs uppercase tracking-[0.24em] text-brand">Where the practice was born</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CH 06 -->
  <section class="bg-bg-base py-20 md:py-24">
    <div class="container-default max-w-5xl">
      <AboutChapter
        num="06"
        era="Today"
        title="The invitation."
        takeaway="I am the invitation, not the insistence. Healing flows through me, not from me."
        body={[
          "Today, I help you experience the Creator's gift: the connection to your Higher Self, the Subconscious, the Holy Spirit. Whatever name you give it — it is the voice that guides us.",
          "Only love exists. I invite you to allow me to guide you, so you can finally receive the messages your Higher Self has been waiting for you to hear.",
        ]}
      />
    </div>
  </section>

  <!-- HEALING-TREE PROMISE -->
  <section class="bg-bg-sunken py-20 md:py-24">
    <div class="container-default grid items-center gap-10 md:grid-cols-[1fr,1.1fr] lg:gap-16">
      <figure class="mx-auto max-w-md md:max-w-none">
        <img
          src="/dodie/healing-tree.jpg"
          alt="Watercolor tree of life with the words: Your body's ability to heal is greater than anyone has permitted you to believe."
          class="w-full h-auto rounded-lg shadow-md"
          loading="lazy"
        />
      </figure>
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-brand">The promise</p>
        <h2 class="mt-3 font-display text-ink">
          <span class="block">You are not broken.</span>
          <span class="italic-accent block text-brand">You are remembering.</span>
        </h2>
        <p class="mt-5 max-w-prose text-lg text-ink-secondary leading-relaxed">
          QHHT doesn't add anything to you. It quiets the noise long enough for what you already are to come back into focus. The body remembers. The Higher Self has been waiting. The work is yours; the conversation is the door.
        </p>
      </div>
    </div>
  </section>

  <!-- CLOSING — doorway video -->
  <ClosingCTA
    headlineLead="Your Higher Self"
    headlineItalic="is already speaking."
    headlineTail="Are you ready to listen?"
    subhead="A conversation with the deepest part of you. Held with confidentiality, recorded for you to keep."
    cta={{ label: 'Book a Session', href: '/book' }}
    trustLine="In-person sessions · Stuart, FL"
  />
</Base>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 600ms ease, transform 600ms ease;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll { opacity: 1; transform: none; transition: none; }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.reveal-on-scroll').forEach((el) => el.classList.add('is-visible'));
      return;
    }
    if (!('IntersectionObserver' in window)) {
      document.querySelectorAll('.reveal-on-scroll').forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      }),
      { rootMargin: '0px 0px -80px 0px', threshold: 0.05 }
    );
    document.querySelectorAll('.reveal-on-scroll').forEach((el) => io.observe(el));
  })();
</script>
