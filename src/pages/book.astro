---
import Base from '@layouts/Base.astro';
import BookingEmbed from '@components/BookingEmbed.astro';
import { getSeo } from '@lib/seo';
import { qhhtService, breadcrumb } from '@lib/schema';

// SSR for /book — calendar ID must resolve from Cloudflare runtime env, not build time.
// See ADR-004 (Option A, applied to this page only).
export const prerender = false;

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const env = ((Astro.locals as any)?.runtime?.env ?? process.env) as Record<string, string | undefined>;
const calendarId = env.GHL_CALENDAR_ID;
const fallbackUrl = env.BOOKING_CALENDAR_FALLBACK_URL;

const seo = getSeo({
  path: '/book',
  title: 'Book a QHHT Session',
  description:
    "Reserve your Quantum Healing Hypnosis session with Dodie Kendall. $300 total, $50 deposit at booking. In-person at my Stuart, FL studio.",
});

const schemas = [
  qhhtService(),
  breadcrumb([
    { name: 'Home', href: '/' },
    { name: 'Book' },
  ]),
];

const next = [
  {
    num: '01',
    title: 'Confirmation email',
    body: "Right after you book, you'll get an email confirming your date and time, with the studio address and instructions for the $250 balance.",
  },
  {
    num: '02',
    title: 'Pre-session prep guide',
    body: "Two days before your session, I'll send you my prep guide and your homework — three questions to bring to the session. It's short. You can do it in 20 minutes.",
  },
  {
    num: '03',
    title: 'Day-of check-in',
    body: "The morning of your session, I'll send a brief check-in text so you know what to expect.",
  },
];
---
<Base seo={seo} schemas={schemas}>
  <section class="section-y bg-bg-base">
    <div class="container-default max-w-4xl">
      <p class="text-xs uppercase tracking-wider text-ink-muted">Booking</p>
      <h1 class="mt-2 font-display">Select a time that feels right.</h1>

      <div class="mt-8 grid gap-8 md:grid-cols-3">
        <div class="rounded-lg border border-border-subtle bg-bg-raised p-5 shadow-sm">
          <p class="text-xs uppercase tracking-wider text-ink-muted">Total</p>
          <p class="mt-1 font-display text-3xl text-ink">$300</p>
          <p class="mt-1 text-xs text-ink-secondary">All-inclusive · session + recording + follow-up call</p>
        </div>
        <div class="rounded-lg border border-border-subtle bg-bg-raised p-5 shadow-sm">
          <p class="text-xs uppercase tracking-wider text-ink-muted">Deposit at booking</p>
          <p class="mt-1 font-display text-3xl text-ink">$50</p>
          <p class="mt-1 text-xs text-ink-secondary">Remaining $250 paid on session day</p>
        </div>
        <div class="rounded-lg border border-border-subtle bg-bg-raised p-5 shadow-sm">
          <p class="text-xs uppercase tracking-wider text-ink-muted">Duration</p>
          <p class="mt-1 font-display text-3xl text-ink">5 hours</p>
          <p class="mt-1 text-xs text-ink-secondary">Pre-session call, session, recording, follow-up</p>
        </div>
      </div>

      <div class="mt-10 max-w-prose space-y-5 text-lg leading-relaxed text-ink-secondary">
        <p>
          Plan for about five hours together — about two hours of conversation, then two to three hours in the session itself. All sessions are in person at my Stuart, FL studio, and completely confidential.
        </p>
        <p>
          If you've never done a QHHT session, that's exactly the right starting point — most clients haven't. Before we meet, I'll send you a short prep guide and we'll have a quick call so you arrive ready.
        </p>
      </div>

      <div class="mt-10 rounded-lg border border-border-subtle bg-bg-sunken p-5 text-sm text-ink-secondary md:p-6">
        <strong class="font-medium text-ink">By scheduling, I understand:</strong>
        <ul class="mt-3 list-disc space-y-1.5 pl-5">
          <li>QHHT is a complementary practice, not medical or psychological treatment.</li>
          <li>Sessions do not diagnose, treat, cure, or prevent any disease.</li>
          <li>Dodie is a QHHT Practitioner trained in the Dolores Cannon lineage — not a licensed physician, psychologist, or psychotherapist.</li>
          <li>My participation is voluntary.</li>
        </ul>
      </div>

      <div class="mt-12">
        <BookingEmbed calendarId={calendarId} fallbackUrl={fallbackUrl} />
      </div>

      <div class="mt-16">
        <header class="mb-8 max-w-2xl">
          <p class="text-xs uppercase tracking-wider text-ink-muted">What happens next</p>
          <h2 class="mt-3 font-display">From booking to session day.</h2>
        </header>
        <ol class="grid gap-6 md:grid-cols-3" role="list">
          {next.map((n) => (
            <li class="rounded-lg border border-border-subtle bg-bg-raised p-6 shadow-sm">
              <div class="flex h-10 w-10 items-center justify-center rounded-pill bg-sage/20 font-display text-base text-ink" aria-hidden="true">{n.num}</div>
              <h3 class="mt-4 font-display text-xl">{n.title}</h3>
              <p class="mt-2 text-ink-secondary leading-relaxed">{n.body}</p>
            </li>
          ))}
        </ol>
      </div>

      <p class="mt-10 text-sm text-ink-muted">
        Your information is held confidentially and used only to coordinate your session and follow-up. See our
        <a href="/privacy" class="text-brand underline">Privacy Policy</a> for details.
      </p>
    </div>
  </section>
</Base>
