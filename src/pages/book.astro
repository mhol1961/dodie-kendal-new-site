---
import Base from '@layouts/Base.astro';
import BookingEmbed from '@components/BookingEmbed.astro';
import { getSeo } from '@lib/seo';
import { qhhtService, breadcrumb } from '@lib/schema';

const seo = getSeo({
  path: '/book',
  title: 'Book a Session',
  description: 'Reserve your 5-hour Quantum Healing Hypnosis session with Dodie Kendall. $300 total, $50 deposit. Palm Beach County and remote.',
});
const schemas = [qhhtService(), breadcrumb([{ name: 'Home', href: '/' }, { name: 'Book' }])];
---
<Base seo={seo} schemas={schemas}>
  <section class="section-y bg-bg-raised">
    <div class="container-default max-w-3xl">
      <p class="text-xs uppercase tracking-wider text-ink-muted mb-3">Booking</p>
      <h1 class="font-display text-ink">Select a time that feels right.</h1>
      <div class="mt-8 space-y-6 text-ink-secondary text-lg max-w-prose">
        <p>
          Each session is 5 hours, in person at my Palm Beach County studio or remotely via Zoom. The total investment is $300, with a $50 deposit to secure your time. All sessions are completely confidential. The remaining $250 is paid on the day of your session.
        </p>
        <p>
          If you've never done a QHHT session, that's exactly the right starting point — most clients haven't. Before we meet, I'll send you a short prep guide and we'll have a quick call so you arrive ready.
        </p>
      </div>

      <div class="mt-10 bg-bg-base border border-border-subtle rounded-lg p-4 text-sm text-ink-secondary">
        <strong class="font-medium text-ink">By scheduling, I understand:</strong>
        <ul class="list-disc pl-5 mt-2 space-y-1">
          <li>QHHT is a complementary practice, not medical or psychological treatment.</li>
          <li>Sessions do not diagnose, treat, cure, or prevent any disease.</li>
          <li>Dodie is a QHHT Practitioner trained in the Dolores Cannon lineage — not a licensed physician, psychologist, or psychotherapist.</li>
          <li>My participation is voluntary.</li>
        </ul>
      </div>

      <div class="mt-12">
        <BookingEmbed />
      </div>

      <!-- TODO Phase 7: "What happens next" 3-step + privacy reassurance. Copy in COPY-DECK.md §Book. -->
    </div>
  </section>
</Base>
