---
import Base from '@layouts/Base.astro';
import ContactForm from '@components/ContactForm.astro';
import { getSeo } from '@lib/seo';
import { breadcrumb } from '@lib/schema';

const SITE_URL = import.meta.env.SITE_URL || 'https://dodiekendall.com';

const seo = getSeo({
  path: '/contact',
  title: 'Contact',
  description:
    "Have a question before booking? Reach Dodie directly — typical response within 24–48 hours, Monday through Saturday.",
});

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: `${SITE_URL}/contact`,
  mainEntity: { '@id': `${SITE_URL}/#business` },
};

const schemas = [
  contactSchema,
  breadcrumb([
    { name: 'Home', href: '/' },
    { name: 'Contact' },
  ]),
];
---
<Base seo={seo} schemas={schemas}>
  <section class="section-y bg-bg-base">
    <div class="container-default grid gap-12 lg:grid-cols-[1fr,360px]">
      <div>
        <p class="text-xs uppercase tracking-wider text-ink-muted">Contact</p>
        <h1 class="mt-2 font-display">Reach out — I'll write back personally.</h1>
        <p class="mt-6 max-w-prose text-lg leading-relaxed text-ink-secondary">
          Have a question before you book? Want to know if QHHT is right for what you're working through?
          Send me a note. I usually respond within 24–48 hours, Monday through Saturday.
        </p>

        <div class="mt-10">
          <ContactForm />
        </div>
      </div>

      <aside class="space-y-6 self-start rounded-lg border border-border-subtle bg-bg-sunken p-6 lg:sticky lg:top-24">
        <div>
          <p class="text-xs uppercase tracking-wider text-ink-muted">Or reach me directly</p>
          <ul class="mt-3 space-y-3 text-sm">
            <li>
              <p class="text-ink-muted">Phone</p>
              <a href="tel:+15612016918" class="text-base text-ink hover:text-brand">1-561-201-6918</a>
            </li>
            <li>
              <p class="text-ink-muted">Email</p>
              <a href="mailto:dodiekendall@gmail.com" class="text-base text-ink hover:text-brand">dodiekendall@gmail.com</a>
            </li>
            <li>
              <p class="text-ink-muted">Hours</p>
              <p class="text-base text-ink">Monday – Saturday<br />9am – 6pm ET</p>
            </li>
            <li>
              <p class="text-ink-muted">Location</p>
              <p class="text-base text-ink">Palm Beach County, FL<br />Remote sessions worldwide</p>
            </li>
          </ul>
        </div>

        <div class="border-t border-border-subtle pt-5">
          <p class="text-xs uppercase tracking-wider text-ink-muted">Ready to book?</p>
          <a
            href="/book"
            class="mt-3 inline-flex w-full items-center justify-center rounded-pill bg-brand px-5 py-2.5 text-sm font-medium text-ink-inverse shadow-sm transition-all hover:bg-brand-hover hover:shadow-md"
          >
            Book a Session
          </a>
        </div>
      </aside>
    </div>
  </section>
</Base>
