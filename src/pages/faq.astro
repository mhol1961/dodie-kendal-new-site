---
import Base from '@layouts/Base.astro';
import Accordion from '@components/ui/Accordion.astro';
import { getSeo } from '@lib/seo';
import { faqPage, breadcrumb } from '@lib/schema';
import { getCollection } from 'astro:content';

const seo = getSeo({
  path: '/faq',
  title: 'Frequently Asked Questions',
  description:
    "Common questions about QHHT sessions, logistics, practice, and aftercare — answered in plain language.",
});

const faqs = (await getCollection('faq').catch(() => [])).sort((a, b) => a.data.order - b.data.order);

const schemas = [
  faqPage(faqs.map((f) => ({ question: f.data.question, answer: f.data.answer }))),
  breadcrumb([
    { name: 'Home', href: '/' },
    { name: 'FAQ' },
  ]),
];

const categories = [
  { key: 'sessions',  label: 'Sessions',  description: 'What a QHHT session looks like.' },
  { key: 'logistics', label: 'Logistics', description: 'Booking, location, pricing, prep.' },
  { key: 'practice',  label: 'Practice',  description: 'Scope, training, and what QHHT is not.' },
  { key: 'aftercare', label: 'Aftercare', description: 'What unfolds in the days after.' },
] as const;

function groupItems(category: typeof categories[number]['key']) {
  return faqs
    .filter((f) => f.data.category === category)
    .map((f) => ({ question: f.data.question, answer: f.data.answer }));
}
---
<Base seo={seo} schemas={schemas}>
  <section class="section-y bg-bg-base">
    <div class="container-default max-w-4xl">
      <p class="text-xs uppercase tracking-wider text-ink-muted">FAQ</p>
      <h1 class="mt-2 font-display">Common questions, answered.</h1>
      <p class="mt-4 max-w-prose text-lg text-ink-secondary">
        Don't see your question here? Reach me via <a href="/contact" class="text-brand underline">the contact form</a>.
      </p>

      {faqs.length === 0 ? (
        <p class="mt-12 text-ink-muted">FAQ entries are being added — check back soon.</p>
      ) : (
        <div class="mt-12 space-y-14">
          {categories.map((cat) => {
            const items = groupItems(cat.key);
            return items.length > 0 ? (
              <section>
                <header class="mb-6">
                  <h2 class="font-display text-2xl md:text-3xl">{cat.label}</h2>
                  <p class="mt-1 text-ink-muted">{cat.description}</p>
                </header>
                <Accordion items={items} idPrefix={`faq-${cat.key}`} />
              </section>
            ) : null;
          })}
        </div>
      )}
    </div>
  </section>

  <section class="section-y bg-sunrise">
    <div class="container-default text-center">
      <h2 class="font-display text-4xl md:text-5xl">Got a question I haven't covered?</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-ink-secondary">
        I read every note personally. Most replies go out within 24–48 hours.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/contact" class="inline-flex items-center justify-center rounded-pill bg-brand px-7 py-3 font-medium text-ink-inverse shadow-md transition-all hover:bg-brand-hover hover:shadow-glow">Send a note</a>
        <a href="/book" class="inline-flex items-center justify-center rounded-pill border border-border-strong px-7 py-3 font-medium text-ink transition-colors hover:border-brand hover:text-brand">Book a Session</a>
      </div>
    </div>
  </section>
</Base>
