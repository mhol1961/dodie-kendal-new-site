---
import Base from '@layouts/Base.astro';
import HomeHero from '@components/HomeHero.astro';
import TrustStrip from '@components/TrustStrip.astro';
import PullQuote from '@components/PullQuote.astro';
import ThreeAct from '@components/ThreeAct.astro';
import FounderSpotlight from '@components/FounderSpotlight.astro';
import LeadMagnetGate from '@components/LeadMagnetGate.astro';
import TestimonialGrid from '@components/TestimonialGrid.astro';
import ClosingCTA from '@components/ClosingCTA.astro';
import { getSeo } from '@lib/seo';
import { qhhtService, breadcrumb } from '@lib/schema';

const seo = getSeo({
  path: '/',
  description:
    "A deeply respectful conversation with your Subconscious. Quantum Healing Hypnosis Technique with Dodie Kendall — in-person sessions in Stuart, FL.",
});

const schemas = [
  qhhtService(),
  breadcrumb([{ name: 'Home' }]),
];

const sessionActs = [
  {
    number: '01',
    eyebrow: 'Before — Set intentions',
    title: 'You bring the questions.',
    body: "We start with a relaxed pre-session conversation — it's all about you. Pain you can't explain, choices you can't quite see, relationships that loop. Whatever has been waiting for an answer, bring it. There are no wrong questions.",
  },
  {
    number: '02',
    eyebrow: 'During — Enter the Theta state',
    title: 'I guide you to the doorway. You walk through.',
    body: "On session day we settle in a quiet room. You recline and let yourself settle. I guide you into the Theta brainwave state — the threshold between waking and dreaming, where the Subconscious can speak clearly. You stay aware. You stay in charge.",
  },
  {
    number: '03',
    eyebrow: 'After — Receive insight',
    title: 'Your Higher Self answers, in its own language.',
    body: "Sometimes through past-life memory. Sometimes through a felt sense in the body. Sometimes through a single clear sentence you've been chasing for years. We record everything. You take the recording home, and the insights keep arriving for weeks.",
  },
];
---
<Base seo={seo} schemas={schemas}>
  <HomeHero />

  <TrustStrip
    items={[
      'Trained in the Dolores Cannon lineage',
      'In-person sessions in Stuart, FL',
      'Audio recording included',
    ]}
  />

  <PullQuote
    quote="I am the invitation, not the insistence."
    attribution="Dodie"
  />

  <!--
    Subhead: "Not therapy. Not regression hypnosis." removed per 2026-06-02 call
    notes (Dodie doesn't want to frame by what it is or isn't here).
    Eyebrow softened from "A 5-hour conversation with your Subconscious" — the
    five-hour-conversation framing is wrong; the session is ~5 hours total with
    ~2-3 hours of hypnosis. See sessionActs body below for fuller framing.
  -->
  <ThreeAct
    eyebrow="A conversation with your Subconscious"
    heading="How a QHHT session"
    headingItalic="unfolds."
    subhead="A guided, deeply respectful conversation with the part of you that has all of your answers and has been waiting for you to ask."
    acts={sessionActs}
    ctaLabel="Read more about the modality"
    ctaHref="/qhht"
  />

  <FounderSpotlight
    role="Founder · Dodie Kendall QHHT"
    headlineLead="Guided by intuition,"
    headlineItalic="grounded in love."
    body={[
      "I'm a native Floridian who spent decades searching — through a long career and a longer set of questions — for who we really are.",
      "That search led me to understand us as multidimensional beings, and then to Dolores Cannon's Quantum Healing Hypnosis Technique. From my first session as a client, I knew this was the work I was born to do.",
    ]}
    credentials={[
      'Dolores Cannon lineage',
      'Stuart, FL',
      'In-person sessions',
    ]}
    cta={{ label: "Read my full story", href: '/about' }}
    photoSrc="/dodie/dodie-sitting-aqua.jpg"
    photoAlt="Dodie Kendall seated and smiling warmly in a soft aqua dress — QHHT Practitioner in Stuart, FL"
  />

  <TestimonialGrid
    heading="What clients say"
    headingItalic="after a session."
    subhead="Different journeys, one thing in common — the moment everything finally made sense."
  />

  <div class="bg-bg-inverse-deeper pb-20 md:pb-24 text-center">
    <a href="/testimonials" class="inline-flex items-center gap-2 rounded-pill border border-teal-glow/30 px-6 py-2.5 text-sm text-inverse transition-colors hover:border-brand hover:text-brand">
      Read all client reviews
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>

  <LeadMagnetGate />

  <ClosingCTA
    headlineLead="Your Higher Self"
    headlineItalic="is already speaking."
    headlineTail="Are you ready to listen?"
    subhead="One session. One audio recording, yours to keep. Reserve your time with a small deposit."
    cta={{ label: 'Book a Session', href: '/book' }}
    trustLine="Stuart, FL · Booking confirmed within 24 hours"
  />
</Base>
