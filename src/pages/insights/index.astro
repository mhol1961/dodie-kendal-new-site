---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import ClosingCTA from '@components/ClosingCTA.astro';
import { getSeo } from '@lib/seo';
import { breadcrumb } from '@lib/schema';
import { getCollection } from 'astro:content';

const SITE_URL = import.meta.env.SITE_URL || 'https://dodiekendall.com';

const seo = getSeo({
  path: '/insights',
  title: 'Insights',
  description:
    "Articles on QHHT, the Subconscious, and the practical side of Quantum Healing Hypnosis with Dodie Kendall.",
});

const posts = (await getCollection('insights', ({ data }) => !data.draft).catch(() => [])).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Map slug → poster image (uses Seedance video poster stills where available)
const heroBySlug: Record<string, string> = {
  'what-happens-in-a-qhht-session': '/video/hourglass-time-poster.jpg',
  'past-life-regression-vs-qhht': '/photos/hero-milky-way.jpg',
  'how-to-prepare-for-your-first-quantum-healing-session': '/video/fountain-pen-write-poster.jpg',
  'choosing-a-qhht-practitioner': '/video/compass-needle-poster.jpg',
};

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  url: `${SITE_URL}/insights`,
  publisher: { '@id': `${SITE_URL}/#business` },
};
const schemas = [
  blogSchema,
  breadcrumb([{ name: 'Home', href: '/' }, { name: 'Insights' }]),
];

const [featured, ...rest] = posts;

// Build the full list of unique tags for chip filtering UI
const tags = Array.from(new Set(posts.flatMap((p) => p.data.tags ?? []))).sort();
---
<Base seo={seo} schemas={schemas}>
  <Hero
    variant="insights"
    eyebrow="Insights"
    headlineLead="Short, practical writing"
    headlineItalic="on what unfolds"
    headlineTail="when you listen."
    subhead="Notes from Dodie on QHHT, preparation, what a session is and is not, and how to find a practitioner you can trust. Read in order or pick whatever you need today."
    bgImage="/photos/hero-aurora-real.jpg"
  />

  {posts.length === 0 ? (
    <section class="section-y bg-bg-base">
      <div class="container-default">
        <p class="text-ink-muted">Posts are being added — check back soon.</p>
      </div>
    </section>
  ) : (
    <>
      <!-- Filter chips (visual, not yet functional — wires up later) -->
      {tags.length > 0 && (
        <section class="bg-bg-sunken py-5 border-y border-border-subtle/40">
          <div class="container-default flex flex-wrap items-center gap-x-3 gap-y-2 text-[11px] uppercase tracking-[0.18em] text-ink-muted">
            <span class="text-brand">Browse:</span>
            <a href="/insights" class="rounded-pill border border-border-strong bg-bg-base px-3 py-1 text-ink hover:border-brand hover:text-brand transition-colors">All</a>
            {tags.map((tag) => (
              <a
                href={`#tag-${tag}`}
                class="rounded-pill border border-border-subtle bg-bg-raised px-3 py-1 text-ink-secondary hover:border-brand hover:text-brand transition-colors"
              >
                {tag.replace(/-/g, ' ')}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Featured post — oversized hero card -->
      {featured && (
        <section class="section-y bg-bg-base">
          <div class="container-default">
            <p class="mb-6 text-[10px] uppercase tracking-[0.22em] text-brand">Featured · Most recent</p>
            <a
              href={`/insights/${featured.slug}/`}
              class="group grid gap-8 md:grid-cols-12 md:gap-12 lg:gap-16"
            >
              <div class="md:col-span-7 lg:col-span-7">
                <div class="relative overflow-hidden rounded-lg">
                  <span aria-hidden="true" class="absolute -inset-4 -z-10 bg-gradient-to-br from-teal/20 via-brand/15 to-transparent blur-2xl"></span>
                  <img
                    src={heroBySlug[featured.slug] ?? '/hero-aurora-poster.jpg'}
                    alt=""
                    width="800"
                    height="500"
                    class="w-full h-auto aspect-[8/5] object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                    loading="eager"
                  />
                </div>
              </div>
              <div class="md:col-span-5 lg:col-span-5 flex flex-col justify-center">
                <p class="text-xs uppercase tracking-[0.22em] text-ink-muted">
                  {featured.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  {' · '}5 min read
                </p>
                <h2 class="mt-4 font-display text-ink leading-[1.05]">
                  {featured.data.title}
                </h2>
                <p class="mt-5 text-lg text-ink-secondary leading-relaxed">{featured.data.description}</p>
                <p class="mt-6 inline-flex items-center gap-3 text-base font-medium text-brand transition-transform group-hover:translate-x-1">
                  Read post →
                </p>
              </div>
            </a>
          </div>
        </section>
      )}

      <!-- Remaining posts — image-led grid -->
      {rest.length > 0 && (
        <section class="section-y bg-bg-base">
          <div class="container-default">
            <header class="mb-12 max-w-2xl">
              <p class="text-xs uppercase tracking-[0.22em] text-brand">More reading</p>
              <h2 class="mt-3 font-display text-ink">
                <span class="block">Keep going.</span>
              </h2>
            </header>
            <ul class="grid gap-8 md:grid-cols-2 lg:grid-cols-3" role="list">
              {rest.map((post) => (
                <li>
                  <a href={`/insights/${post.slug}/`} class="group flex h-full flex-col">
                    <div class="relative overflow-hidden rounded-lg">
                      <img
                        src={heroBySlug[post.slug] ?? '/hero-aurora-poster.jpg'}
                        alt=""
                        width="800"
                        height="500"
                        class="w-full h-auto aspect-[8/5] object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                        loading="lazy"
                      />
                      <span aria-hidden="true" class="pointer-events-none absolute inset-0 bg-gradient-to-t from-bg-inverse/30 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></span>
                    </div>
                    <p class="mt-5 text-xs uppercase tracking-[0.22em] text-ink-muted">
                      {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </p>
                    <h3 class="mt-2 font-display text-2xl text-ink leading-snug transition-colors group-hover:text-brand">
                      {post.data.title}
                    </h3>
                    <p class="mt-3 text-ink-secondary leading-relaxed">{post.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}
    </>
  )}

  <ClosingCTA
    headlineLead="Read enough."
    headlineItalic="Ready to listen?"
    cta={{ label: 'Book a Session', href: '/book' }}
    trustLine="$300 · 5 hours · Palm Beach FL or remote via Zoom"
  />
</Base>
