---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import Accordion from '@components/ui/Accordion.astro';
import { getSeo } from '@lib/seo';
import { qhhtService, faqPage, breadcrumb } from '@lib/schema';
import { getCollection } from 'astro:content';

const seo = getSeo({
  path: '/qhht',
  title: 'Quantum Healing Hypnosis Technique',
  description:
    "QHHT is a 5-hour guided conversation with your Subconscious, developed by Dolores Cannon. Learn how a session unfolds and what to expect.",
});

const faq = (await getCollection('faq').catch(() => []))
  .filter((f) => f.data.category === 'sessions' || f.data.category === 'practice')
  .sort((a, b) => a.data.order - b.data.order)
  .map((f) => ({ question: f.data.question, answer: f.data.answer }));

const schemas = [
  qhhtService(),
  faqPage(faq),
  breadcrumb([
    { name: 'Home', href: '/' },
    { name: 'QHHT' },
  ]),
];

const timeline = [
  {
    num: '01',
    title: 'Pre-session call (30 min)',
    body: "We talk on the phone or over Zoom. You bring the questions you want your Higher Self to answer. There's no wrong question. I'll help you shape them.",
  },
  {
    num: '02',
    title: 'Session day (5 hours)',
    body: "You arrive at the studio (or settle in for a remote session). We share a conversation, then a short guided induction into the Theta state. The session itself usually runs 3–4 hours; you'll feel like you woke from a deep nap.",
  },
  {
    num: '03',
    title: 'The recording',
    body: "Most of what's said you won't remember in detail — the Theta state is like that. I record everything (audio only, with your consent). You take the recording home.",
  },
  {
    num: '04',
    title: 'Integration',
    body: "The week after a session often unfolds quietly. Old patterns sometimes loosen. New clarity surfaces. I'm available for one follow-up call within 30 days at no extra cost.",
  },
];
---
<Base seo={seo} schemas={schemas}>
  <Hero
    variant="qhht"
    eyebrow="The modality"
    headline="Quantum Healing Hypnosis Technique, explained."
    subhead="QHHT is a guided journey into the part of you that already knows. Developed by the late Dolores Cannon, it's a 5-hour, deeply respectful conversation with your Subconscious — and it's at the heart of every session I offer."
  />

  <section class="section-y bg-bg-base">
    <div class="container-prose">
      <p class="text-xs uppercase tracking-wider text-ink-muted">What is QHHT</p>
      <h2 class="mt-2 font-display text-3xl md:text-4xl">A gentle way into the archive.</h2>
      <div class="mt-6 space-y-5 text-lg leading-relaxed text-ink-secondary">
        <p>Think of your mind like a vast library. Your conscious mind is the front desk — busy, logical, handling the daily tasks. But behind those doors is the Subconscious, a deep archive that holds the records of everything your soul has ever experienced.</p>
        <p>QHHT is a gentle, guided way into that archive. We use the Theta brainwave state — the threshold between waking and dreaming — so the conscious noise quiets and the Subconscious can speak clearly. You stay in the driver's seat the whole time. You set the questions. Your Higher Self answers.</p>
        <p>This is not regression hypnosis. It's not therapy. It's not channeling. It's not a performance. It is what Dolores Cannon called a <em>Sacred Technology</em> — and that's a fair description.</p>
      </div>
    </div>
  </section>

  <section class="section-y bg-bg-base">
    <div class="container-default">
      <header class="mb-12 max-w-2xl">
        <p class="text-xs uppercase tracking-wider text-ink-muted">What to expect</p>
        <h2 class="mt-3 font-display">A clear path, from intake to integration.</h2>
      </header>
      <ol class="grid gap-8 md:grid-cols-2" role="list">
        {timeline.map((t) => (
          <li class="flex gap-5 rounded-lg border border-border-subtle bg-bg-raised p-6 shadow-md">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-pill bg-sage/20 font-display text-xl text-ink" aria-hidden="true">
              {t.num}
            </div>
            <div>
              <h3 class="font-display text-xl">{t.title}</h3>
              <p class="mt-2 text-ink-secondary leading-relaxed">{t.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section-y bg-bg-base">
    <div class="container-default">
      <header class="mb-12 max-w-2xl">
        <p class="text-xs uppercase tracking-wider text-ink-muted">Common questions</p>
        <h2 class="mt-3 font-display">Sessions &amp; practice — answered.</h2>
        <p class="mt-3 text-lg text-ink-secondary">Full FAQ — including logistics and aftercare — is on the <a href="/faq" class="text-brand underline">FAQ page</a>.</p>
      </header>
      <div class="max-w-3xl">
        <Accordion items={faq} idPrefix="qhht-faq" />
      </div>
    </div>
  </section>

  <section class="section-y bg-sunrise">
    <div class="container-default text-center">
      <h2 class="font-display text-4xl md:text-5xl">Ready for the conversation?</h2>
      <div class="mt-8">
        <a
          href="/book"
          class="inline-flex items-center justify-center rounded-pill bg-brand px-8 py-4 text-lg font-medium text-ink-inverse shadow-md transition-all hover:bg-brand-hover hover:shadow-glow"
        >
          Book a Session
        </a>
      </div>
    </div>
  </section>
</Base>
