---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import Accordion from '@components/ui/Accordion.astro';
import PullQuote from '@components/PullQuote.astro';
import ClosingCTA from '@components/ClosingCTA.astro';
import SectionDivider from '@components/SectionDivider.astro';
import { getSeo } from '@lib/seo';
import { qhhtService, faqPage, breadcrumb } from '@lib/schema';
import { getCollection } from 'astro:content';

const seo = getSeo({
  path: '/qhht',
  title: 'Quantum Healing Hypnosis Technique',
  description:
    "QHHT is a 5-hour guided conversation with your Subconscious, developed by Dolores Cannon. Learn how a session unfolds and what to expect.",
});

const faq = (await getCollection('faq').catch(() => []))
  .filter((f) => f.data.category === 'sessions' || f.data.category === 'practice')
  .sort((a, b) => a.data.order - b.data.order)
  .map((f) => ({ question: f.data.question, answer: f.data.answer }));

const schemas = [
  qhhtService(),
  faqPage(faq),
  breadcrumb([{ name: 'Home', href: '/' }, { name: 'QHHT' }]),
];

const isnot = [
  { label: 'Therapy', detail: 'It is not psychotherapy and not a replacement for licensed mental-health care.' },
  { label: 'Medical care', detail: 'It does not diagnose, treat, cure, or prevent any disease or condition.' },
  { label: 'Past-life regression', detail: 'Past-life material may surface — but the conversation is much broader than just prior lifetimes.' },
  { label: 'Channeling',  detail: 'Your Subconscious is your own. Nothing speaks through me. I guide; you receive.' },
  { label: 'A performance', detail: "There is no expectation that anything dramatic 'has to' happen. Many sessions are quiet and clear." },
];

const timeline = [
  { num: '01', tag: 'Before', title: 'Pre-session call (30 min)', body: "We talk on the phone or over Zoom. You bring the questions you want your Higher Self to answer. There's no wrong question. I'll help you shape them." },
  { num: '02', tag: 'Day of', title: 'The session (5 hours)', body: "You arrive at the studio (or settle in for a remote session). We share a conversation, then a short guided induction into the Theta state. The session itself usually runs 3–4 hours; you'll feel like you woke from a deep nap." },
  { num: '03', tag: 'The artifact', title: 'Your audio recording', body: "Most of what's said you won't remember in detail — the Theta state is like that. I record everything (audio only, with your consent). You take the recording home." },
  { num: '04', tag: 'After', title: 'Integration window', body: "The week after a session often unfolds quietly. Old patterns sometimes loosen. New clarity surfaces. I'm available for one follow-up call within 30 days at no extra cost." },
];
---
<Base seo={seo} schemas={schemas}>
  <Hero
    variant="qhht"
    eyebrow="The modality"
    headlineLead="Quantum Healing Hypnosis"
    headlineItalic="Technique,"
    headlineTail="explained."
    subhead="A 5-hour, deeply respectful conversation with the deepest part of you. Developed by the late Dolores Cannon, refined over four decades, and at the heart of every session I offer."
  />

  <!-- Origin band -->
  <section class="bg-bg-sunken py-10">
    <div class="container-default grid items-center gap-6 md:grid-cols-[1fr,2fr] md:gap-12">
      <div>
        <p class="text-[10px] uppercase tracking-[0.22em] text-ink-muted">Originator</p>
        <p class="mt-2 font-display text-3xl text-ink">Dolores Cannon</p>
        <p class="mt-1 text-sm text-ink-muted">1931 – 2014 · Hypnotist · Researcher · Author</p>
      </div>
      <p class="text-ink-secondary leading-relaxed md:text-lg">
        Dolores Cannon developed QHHT over more than four decades, working with thousands of clients across the U.S. and abroad. The method is taught and certified directly through her organization. I trained in this lineage and continue to study within the QHHT community.
      </p>
    </div>
  </section>

  <!-- The library metaphor — Dodie's actual analogy -->
  <section class="section-y bg-bg-base">
    <div class="container-default grid items-start gap-12 md:grid-cols-12 md:gap-16">
      <!-- Symbolic art column -->
      <div class="md:col-span-5 lg:col-span-5">
        <div class="sticky top-28 relative">
          <span aria-hidden="true" class="absolute -inset-6 -z-10 rounded-lg bg-gradient-to-br from-teal/20 via-brand/15 to-transparent blur-2xl"></span>
          <!-- Inline "archive doorway" symbolic SVG -->
          <svg viewBox="0 0 480 600" class="w-full h-auto rounded-lg bg-bg-inverse text-inverse" aria-hidden="true">
            <defs>
              <linearGradient id="doorGlow" x1="50%" y1="0%" x2="50%" y2="100%">
                <stop offset="0%" stop-color="oklch(0.78 0.13 195)" stop-opacity="0.85"/>
                <stop offset="100%" stop-color="oklch(0.42 0.10 195)" stop-opacity="0"/>
              </linearGradient>
              <linearGradient id="floor" x1="50%" y1="0%" x2="50%" y2="100%">
                <stop offset="0%" stop-color="oklch(0.18 0.018 240)"/>
                <stop offset="100%" stop-color="oklch(0.10 0.020 240)"/>
              </linearGradient>
              <radialGradient id="bloom" cx="50%" cy="35%" r="35%">
                <stop offset="0%" stop-color="oklch(0.78 0.13 195)" stop-opacity="0.45"/>
                <stop offset="60%" stop-color="oklch(0.18 0.018 240)" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <!-- Backdrop -->
            <rect width="480" height="600" fill="url(#floor)"/>
            <rect width="480" height="600" fill="url(#bloom)"/>
            <!-- Doorway -->
            <path d="M180 540 L180 230 Q180 130 240 130 Q300 130 300 230 L300 540 Z" fill="url(#doorGlow)" opacity="0.7"/>
            <path d="M180 540 L180 230 Q180 130 240 130 Q300 130 300 230 L300 540" stroke="oklch(0.78 0.13 195)" stroke-width="1.2" fill="none" opacity="0.9"/>
            <!-- Inner threshold light -->
            <path d="M220 540 L220 250 Q220 165 240 165 Q260 165 260 250 L260 540 Z" fill="oklch(0.97 0.008 85)" opacity="0.12"/>
            <!-- Floor line -->
            <line x1="40" y1="540" x2="440" y2="540" stroke="oklch(0.97 0.008 85 / 0.18)" stroke-width="1"/>
            <!-- Stars / motes -->
            <g fill="oklch(0.97 0.008 85)" opacity="0.85">
              <circle cx="120" cy="120" r="1.3"/>
              <circle cx="380" cy="80" r="1.6"/>
              <circle cx="80" cy="280" r="1"/>
              <circle cx="400" cy="240" r="1.3"/>
              <circle cx="160" cy="80" r="0.9"/>
              <circle cx="330" cy="180" r="0.9"/>
              <circle cx="60"  cy="420" r="1"/>
              <circle cx="420" cy="380" r="1.2"/>
              <circle cx="240" cy="80"  r="0.8"/>
            </g>
            <!-- Footprint -->
            <ellipse cx="240" cy="555" rx="32" ry="6" fill="oklch(0.78 0.13 195)" opacity="0.55"/>
          </svg>
          <p class="mt-4 text-center text-xs uppercase tracking-[0.22em] text-ink-muted">The threshold to the archive</p>
        </div>
      </div>

      <!-- Copy column -->
      <div class="md:col-span-7 lg:col-span-7">
        <p class="text-xs uppercase tracking-[0.22em] text-brand">What is QHHT</p>
        <h2 class="mt-3 font-display text-ink">
          <span class="block">A library you have</span>
          <span class="italic-accent block text-brand">always carried.</span>
        </h2>

        <div class="mt-7 space-y-5 text-lg leading-relaxed text-ink-secondary">
          <p>Think of your mind like a vast library. Your conscious mind is the front desk — busy, logical, handling the daily tasks. But behind those doors is the Subconscious: a deep archive that holds the records of everything your soul has ever experienced.</p>
          <p>QHHT is a gentle, guided way into that archive. We use the Theta brainwave state — the threshold between waking and dreaming — so the conscious noise quiets and the Subconscious can speak clearly. You stay in the driver's seat the whole time. You set the questions. Your Higher Self answers.</p>
          <p class="font-serif text-2xl text-ink leading-snug">This is what Dolores Cannon called a <em class="italic-accent">Sacred Technology</em> — and that's a fair description.</p>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider glyph="seed" color="brand" />

  <!-- "What QHHT is NOT" — important CRO + scope clarity moment -->
  <section class="section-y bg-bg-base">
    <div class="container-default">
      <header class="mb-12 max-w-3xl">
        <p class="text-xs uppercase tracking-[0.22em] text-brand">Be clear about what this is</p>
        <h2 class="mt-3 font-display text-ink">
          <span class="block">A few important things</span>
          <span class="italic-accent block text-brand">QHHT is not.</span>
        </h2>
        <p class="mt-5 max-w-2xl text-lg text-ink-secondary leading-relaxed">
          Misunderstandings about hypnosis are common. To make sure we start from the same place — here is what QHHT is, and what it is not.
        </p>
      </header>

      <ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-3" role="list">
        {isnot.map((it) => (
          <li class="rounded-lg border border-border-subtle bg-bg-raised p-6 shadow-sm">
            <p class="text-xs uppercase tracking-[0.22em] text-brand">Not</p>
            <p class="mt-2 font-display text-xl text-ink">{it.label}</p>
            <p class="mt-3 text-sm text-ink-secondary leading-relaxed">{it.detail}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <PullQuote
    quote="You stay aware. You stay in charge. I'm the guide; the work is yours."
    attribution="Dodie"
  />

  <!-- The session timeline — horizontal stepped layout -->
  <section class="section-y bg-bg-sunken">
    <div class="container-default">
      <header class="mb-14 max-w-2xl">
        <p class="text-xs uppercase tracking-[0.22em] text-brand">What to expect</p>
        <h2 class="mt-3 font-display text-ink">A clear path, from intake to integration.</h2>
      </header>

      <ol class="relative grid gap-y-12 md:grid-cols-4 md:gap-x-6">
        <!-- Connecting hairline (desktop) -->
        <span aria-hidden="true" class="hidden md:block absolute left-0 right-0 top-7 h-px bg-brand/30"></span>
        {timeline.map((t) => (
          <li class="relative">
            <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full bg-bg-raised border border-brand font-display text-xl text-brand shadow-sm">
              {t.num}
            </div>
            <p class="mt-5 text-[10px] uppercase tracking-[0.22em] text-ink-muted">{t.tag}</p>
            <h3 class="mt-1 font-display text-xl text-ink leading-snug">{t.title}</h3>
            <p class="mt-3 text-ink-secondary leading-relaxed">{t.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- FAQ subset -->
  <section class="section-y bg-bg-base">
    <div class="container-default">
      <header class="mb-12 max-w-2xl">
        <p class="text-xs uppercase tracking-[0.22em] text-brand">Common questions</p>
        <h2 class="mt-3 font-display text-ink">
          <span class="block">Sessions and practice</span>
          <span class="italic-accent block text-brand">— answered.</span>
        </h2>
        <p class="mt-5 text-lg text-ink-secondary">Logistics and aftercare live on the <a href="/faq" class="text-brand underline">FAQ page</a>.</p>
      </header>
      <div class="max-w-3xl">
        <Accordion items={faq} idPrefix="qhht-faq" />
      </div>
    </div>
  </section>

  <ClosingCTA
    headlineLead="Ready for the"
    headlineItalic="conversation?"
    subhead="One 5-hour session. The questions you bring. The answers waiting on the other side of the threshold."
    cta={{ label: 'Book a Session', href: '/book' }}
    trustLine="$300 · 5 hours · Palm Beach FL or remote via Zoom"
  />
</Base>
