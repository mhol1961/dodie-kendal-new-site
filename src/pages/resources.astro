---
import Base from '@layouts/Base.astro';
import { getSeo } from '@lib/seo';
import { breadcrumb } from '@lib/schema';

const seo = getSeo({
  path: '/resources',
  title: 'Resources',
  description:
    "Trusted resources Dodie Kendall recommends — doTERRA essential oils and natural products, and QHHT Level 1 practitioner certification.",
});

const schemas = [breadcrumb([{ name: 'Home', href: '/' }, { name: 'Resources' }])];

const resources = [
  {
    name: 'doTERRA',
    tag: 'Essential oils & natural products',
    body: "Aromatherapy oils and other natural, high-quality products I know and use. Explore the range through my doTERRA storefront.",
    href: 'https://my.doterra.com/dodiekendall',
    cta: 'Visit my doTERRA store',
  },
  {
    name: 'QHHT Level 1 Certification',
    tag: 'For future practitioners',
    body: "Feeling called to this work yourself? QHHT Level 1 is the official certification in the Dolores Cannon lineage — the same training that started my own practice.",
    href: 'https://shop.qhhtofficial.com/doreenkendall',
    cta: 'Explore QHHT certification',
  },
];
---
<Base seo={seo} schemas={schemas}>
  <section class="section-y bg-bg-base">
    <div class="container-default max-w-4xl">
      <p class="text-xs uppercase tracking-wider text-ink-muted">Resources</p>
      <h1 class="mt-2 font-display">A few things I recommend.</h1>
      <p class="mt-6 max-w-prose text-lg leading-relaxed text-ink-secondary">
        These are resources I know, use, and trust — shared here in case they support your own path, whether that's caring for yourself day to day or stepping into this work as a practitioner.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {resources.map((r) => (
          <article class="flex flex-col rounded-lg border border-border-subtle bg-bg-raised p-6 shadow-sm md:p-8">
            <p class="text-[10px] uppercase tracking-[0.24em] text-brand">{r.tag}</p>
            <h2 class="mt-2 font-display text-2xl text-ink">{r.name}</h2>
            <p class="mt-3 flex-1 text-ink-secondary leading-relaxed">{r.body}</p>
            <a
              href={r.href}
              target="_blank"
              rel="noopener sponsored"
              class="mt-6 inline-flex w-fit items-center rounded-pill bg-brand px-5 py-2 text-sm font-medium text-ink-inverse shadow-sm transition-all hover:bg-brand-hover hover:shadow-md"
            >
              {r.cta}
            </a>
          </article>
        ))}
      </div>

      <p class="mt-12 max-w-prose text-sm text-ink-muted">
        Some links on this page are affiliate links. If you choose to purchase through them, I may earn a small commission at no additional cost to you. I only share resources I genuinely believe in.
      </p>
    </div>
  </section>
</Base>
